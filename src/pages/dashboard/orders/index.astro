---
import Layout from '@/layouts/Layout.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import { getSessionFromCookies } from '@/lib/auth';
import { getSellerOrders } from '@/lib/cosmic';
import type { Order } from '@/types';

const session = getSessionFromCookies(Astro.cookies);
if (!session?.isSeller || !session?.sellerId) return Astro.redirect('/login');

const orders = await getSellerOrders(session.sellerId);

const pendingOrders = orders.filter((o: Order) => !o.metadata.shipped).length;
const shippedOrders = orders.filter((o: Order) => o.metadata.shipped).length;
---

<Layout title="Orders - NoxMarket">
  <Header />

  <main class="py-16 bg-gray-50 min-h-screen">
    <div class="container-custom">

      <div class="mb-12 flex flex-col md:flex-row md:items-center md:justify-between gap-4">
        <div>
          <h1 class="text-5xl font-medium tracking-tight text-gray-900 mb-2">Orders</h1>
          <p class="text-xl text-gray-600">Manage and ship your customer orders</p>
        </div>
        <a href="/dashboard" class="btn btn-secondary">← Back to Dashboard</a>
      </div>

      <!-- Stats -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-12">
        <div class="card-elevated p-6">
          <p class="text-gray-600 text-sm font-medium mb-1">Total Orders</p>
          <p class="text-4xl font-medium text-gray-900">{orders.length}</p>
        </div>
        <div class="card-elevated p-6">
          <p class="text-gray-600 text-sm font-medium mb-1">Pending Shipment</p>
          <p class="text-4xl font-medium text-orange-600">{pendingOrders}</p>
        </div>
        <div class="card-elevated p-6">
          <p class="text-gray-600 text-sm font-medium mb-1">Shipped</p>
          <p class="text-4xl font-medium text-green-600">{shippedOrders}</p>
        </div>
      </div>

      <!-- Orders List -->
      <div class="card-elevated p-8">
        {orders.length === 0 ? (
          <div class="text-center py-20 bg-gray-50 rounded-3xl">
            <div class="w-20 h-20 bg-gray-100 rounded-full flex items-center justify-center mx-auto mb-4">
              <svg class="w-10 h-10 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 13V6a2 2 0 00-2-2H6a2 2 0 00-2 2v7m16 0v5a2 2 0 01-2 2H6a2 2 0 01-2-2v-5m16 0h-2.586a1 1 0 00-.707.293l-2.414 2.414a1 1 0 01-.707.293h-3.172a1 1 0 01-.707-.293l-2.414-2.414A1 1 0 006.586 13H4" />
              </svg>
            </div>
            <h3 class="text-2xl font-medium text-gray-900 mb-2">No Orders Yet</h3>
            <p class="text-gray-600">Orders will appear here when customers purchase your products</p>
          </div>
        ) : (
          <div class="space-y-4">
            {orders.map((order: Order) => (
              <div class="card p-6 hover:shadow-lg transition-shadow">
                <div class="flex flex-col lg:flex-row lg:items-start lg:justify-between gap-6">

                  <!-- Left: Customer + Items -->
                  <div class="flex-1">
                    <div class="flex items-start justify-between mb-4">
                      <div>
                        <div class="flex items-center gap-3 mb-2">
                          <h3 class="font-mono text-lg font-semibold text-gray-900">#{order.slug}</h3>
                          <span class={`chip text-xs ${order.metadata.shipped ? 'bg-blue-100 text-blue-800' : 'bg-orange-100 text-orange-800'}`}>
                            {order.metadata.shipped ? 'shipped' : 'pending'}
                          </span>
                        </div>
                        <p class="text-sm text-gray-500">
                          {new Date(order.metadata.created_at).toLocaleDateString('en-US', {
                            month: 'short', day: 'numeric', year: 'numeric',
                            hour: '2-digit', minute: '2-digit'
                          })}
                        </p>
                      </div>
                      <div class="text-right">
                        <p class="text-2xl font-bold text-gray-900">{order.metadata.total}</p>
                      </div>
                    </div>

                    <div class="mb-4 p-4 bg-gray-50 rounded-xl">
                      <p class="text-xs font-medium text-gray-500 mb-2">CUSTOMER</p>
                      <p class="font-medium text-gray-900">{order.metadata.buyer_name}</p>
                      <p class="text-sm text-gray-600">{order.metadata.buyer_email}</p>
                    </div>

                    {order.metadata.items && (
                      <div class="mb-4">
                        <p class="text-xs font-medium text-gray-500 mb-2">ITEMS</p>
                        <p class="text-sm text-gray-900">{order.metadata.items}</p>
                      </div>
                    )}
                  </div>

                  <!-- Right: Shipping -->
                  <div class="lg:w-1/3 lg:border-l lg:pl-6">
                    <div class="flex items-center gap-2 mb-4">
                      <svg class="w-5 h-5 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
                      </svg>
                      <h4 class="font-semibold text-gray-900">Shipping Address</h4>
                    </div>

                    {order.metadata.shipping_address ? (
                      <div class="bg-blue-50 rounded-xl p-4">
                        <pre class="text-sm text-gray-700 font-sans whitespace-pre-wrap">{order.metadata.shipping_address}</pre>
                      </div>
                    ) : (
                      <div class="bg-gray-50 rounded-xl p-4">
                        <p class="text-sm text-gray-500 italic">No shipping address provided</p>
                      </div>
                    )}

                    <div class="mt-4 pt-4 border-t flex items-center justify-between text-sm">
                      <span class="text-gray-600">Stripe Session:</span>
                      <span class="font-mono text-xs text-gray-500 truncate max-w-[140px]">{order.metadata.stripe_session}</span>
                    </div>
                  </div>
                </div>

                <div class="mt-6 pt-6 border-t flex items-center justify-between">
                  <button
                    class={`btn text-sm ${order.metadata.shipped ? 'btn-secondary' : 'btn-primary'}`}
                    data-order-id={order.id}
                    data-shipped={order.metadata.shipped ? 'true' : 'false'}
                    onclick="toggleShipped(this)"
                  >
                    {order.metadata.shipped ? '✓ Marked as Shipped' : 'Mark as Shipped'}
                  </button>
                  <a href={`/dashboard/orders/${order.id}`} class="text-blue-600 text-sm font-medium hover:underline">
                    View Details →
                  </a>
                </div>
              </div>
            ))}
          </div>
        )}
      </div>
    </div>
  </main>

  <Footer />
</Layout>

<script>
  async function toggleShipped(btn: HTMLButtonElement) {
    const orderId = btn.dataset.orderId;
    const isShipped = btn.dataset.shipped === 'true';
    btn.disabled = true;
    btn.textContent = 'Updating…';

    try {
      const res = await fetch('/api/seller/mark-shipped', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ orderId, shipped: !isShipped }),
      });
      if (!res.ok) throw new Error();
      btn.dataset.shipped = (!isShipped).toString();
      btn.textContent = !isShipped ? '✓ Marked as Shipped' : 'Mark as Shipped';
      btn.className = `btn text-sm ${!isShipped ? 'btn-secondary' : 'btn-primary'}`;
    } catch {
      btn.textContent = 'Failed — try again';
    } finally {
      btn.disabled = false;
    }
  }

  (window as any).toggleShipped = toggleShipped;
</script>