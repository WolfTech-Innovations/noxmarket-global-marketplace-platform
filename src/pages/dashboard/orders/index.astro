---
// src/pages/dashboard/seller.astro
import Layout from '@/layouts/Layout.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import { getSessionFromCookies } from '@/lib/auth';

const session = getSessionFromCookies(Astro.cookies);
if (!session?.sellerId) return Astro.redirect('/login');

const sid        = session.sellerId;
const sellerName = session.businessName || session.name || 'Seller';
const hasStripe  = !!session.stripeAccountId;

const BUCKET = import.meta.env.COSMIC_BUCKET_SLUG;
const RKEY   = import.meta.env.COSMIC_READ_KEY;

// Fetch pending ship notifications server-side
const query = encodeURIComponent(JSON.stringify({ type: 'ship-notifications', 'metadata.seller_id': sid }));
const props = encodeURIComponent('id,title,metadata.buyer_name,metadata.buyer_email,metadata.items,metadata.total,metadata.shipped,metadata.stripe_session,metadata.created_at');
const notifRes  = await fetch(
  `https://api.cosmicjs.com/v3/buckets/${BUCKET}/objects?query=${query}&props=${props}&limit=50&status=published&useCache=false`,
  { headers: { Authorization: `Bearer ${RKEY}` } }
);
const notifData = await notifRes.json();
const orders    = notifData.objects ?? [];
---

<Layout title="Seller Dashboard — Nox">
  <Header />

  <main class="min-h-screen bg-gray-50 py-10">
    <div class="container-custom max-w-5xl">

      <!-- Page header -->
      <div class="mb-8 flex items-center justify-between flex-wrap gap-4">
        <div>
          <h1 class="text-3xl font-bold text-gray-900">Seller Dashboard</h1>
          <p class="text-gray-500 mt-1 text-sm">{sellerName}</p>
        </div>
        <a href="/sell/clickz" class="btn btn-primary text-sm">+ Post a Clickz</a>
      </div>

      <!-- Balance card -->
      <div class="card-elevated p-6 mb-8 bg-gradient-to-br from-indigo-600 to-blue-600 text-white rounded-2xl">
        <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-6">
          <div>
            <p class="text-indigo-200 text-xs uppercase tracking-widest mb-1">Available Balance</p>
            <p class="text-4xl font-bold" id="bal-avail">—</p>
            <p class="text-indigo-200 text-sm mt-1">Pending: <span id="bal-pending">—</span></p>
          </div>
          <div class="flex flex-col gap-3 sm:items-end">
            {hasStripe ? (
              <>
                <div class="flex items-center gap-3">
                  <input
                    id="withdraw-amt"
                    type="number"
                    min="1"
                    step="0.01"
                    placeholder="Amount (USD)"
                    class="w-36 bg-white/15 border border-white/25 rounded-lg px-3 py-2 text-white placeholder-white/50 text-sm outline-none focus:border-white/60"
                  />
                  <button id="withdraw-btn" class="bg-white text-indigo-700 font-bold text-sm px-5 py-2 rounded-lg hover:bg-indigo-50 transition disabled:opacity-40">
                    Withdraw
                  </button>
                </div>
                <button id="express-btn" class="text-indigo-200 hover:text-white text-xs underline underline-offset-2 text-right">
                  Open Stripe Dashboard →
                </button>
                <p id="withdraw-msg" class="text-xs text-indigo-200 hidden"></p>
              </>
            ) : (
              <a href="/become-seller#stripe" class="bg-white text-indigo-700 font-bold text-sm px-5 py-2 rounded-lg hover:bg-indigo-50 transition">
                Connect Stripe →
              </a>
            )}
          </div>
        </div>
      </div>

      <!-- Orders -->
      <div class="card-elevated rounded-2xl overflow-hidden">
        <div class="px-6 py-4 border-b border-gray-100 flex items-center justify-between">
          <h2 class="font-semibold text-gray-900 text-lg">Orders to Ship</h2>
          <span class="text-xs text-gray-400 bg-gray-100 rounded-full px-3 py-1" id="order-count">
            {orders.length} order{orders.length !== 1 ? 's' : ''}
          </span>
        </div>

        {orders.length === 0 ? (
          <div class="py-20 text-center text-gray-400">
            <svg class="w-12 h-12 mx-auto mb-3 opacity-30" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/>
            </svg>
            <p class="text-sm">No pending orders — you're all caught up!</p>
          </div>
        ) : (
          <div id="order-list">
            {orders.map((o: any) => (
              <div
                class={`order-row px-6 py-5 border-b border-gray-50 last:border-0 flex flex-col sm:flex-row sm:items-center gap-4 transition-opacity ${o.metadata?.shipped ? 'opacity-40' : ''}`}
                data-id={o.id}
                data-shipped={String(!!o.metadata?.shipped)}
              >
                <!-- Status dot -->
                <div class="flex-shrink-0">
                  <div class={`w-3 h-3 rounded-full ${o.metadata?.shipped ? 'bg-green-400' : 'bg-amber-400 animate-pulse'}`}></div>
                </div>

                <!-- Order info -->
                <div class="flex-1 min-w-0">
                  <p class="font-semibold text-gray-900 text-sm">{o.metadata?.buyer_name ?? 'Buyer'}</p>
                  <p class="text-xs text-gray-500 mt-0.5 truncate">{o.metadata?.items ?? '—'}</p>
                  <p class="text-xs text-gray-400 mt-0.5">
                    {new Date(o.metadata?.created_at ?? '').toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
                  </p>
                </div>

                <!-- Total -->
                <div class="text-right flex-shrink-0">
                  <p class="font-bold text-gray-900 text-sm">{o.metadata?.total ?? '—'}</p>
                </div>

                <!-- Actions -->
                <div class="flex gap-2 flex-shrink-0">
                  <!-- Buyer details toggle -->
                  <button
                    class="details-btn text-xs border border-gray-200 rounded-lg px-3 py-2 hover:bg-gray-50 transition text-gray-600"
                    data-email={o.metadata?.buyer_email ?? ''}
                    data-name={o.metadata?.buyer_name ?? ''}
                    data-items={o.metadata?.items ?? ''}
                    data-session={o.metadata?.stripe_session ?? ''}
                  >
                    Details
                  </button>

                  <!-- Ship toggle -->
                  {!o.metadata?.shipped ? (
                    <button
                      class="ship-btn text-xs bg-green-600 hover:bg-green-700 text-white rounded-lg px-3 py-2 transition font-semibold disabled:opacity-40"
                      data-id={o.id}
                    >
                      Mark Shipped
                    </button>
                  ) : (
                    <span class="text-xs text-green-600 font-semibold flex items-center gap-1">
                      <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/>
                      </svg>
                      Shipped
                    </span>
                  )}
                </div>
              </div>
            ))}
          </div>
        )}
      </div>

    </div>
  </main>

  <!-- Buyer details modal -->
  <div id="modal" class="fixed inset-0 z-50 hidden items-center justify-center p-4 bg-black/50 backdrop-blur-sm">
    <div class="bg-white rounded-2xl shadow-2xl max-w-md w-full p-6">
      <div class="flex items-center justify-between mb-5">
        <h3 class="font-bold text-gray-900 text-lg">Buyer Details</h3>
        <button id="modal-close" class="text-gray-400 hover:text-gray-600">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
          </svg>
        </button>
      </div>
      <dl class="space-y-3 text-sm">
        <div class="flex justify-between gap-4">
          <dt class="text-gray-500">Name</dt>
          <dd class="font-medium text-gray-900 text-right" id="m-name">—</dd>
        </div>
        <div class="flex justify-between gap-4">
          <dt class="text-gray-500">Email</dt>
          <dd class="font-medium text-gray-900 text-right" id="m-email">—</dd>
        </div>
        <div class="flex justify-between gap-4 border-t pt-3">
          <dt class="text-gray-500">Items</dt>
          <dd class="font-medium text-gray-900 text-right" id="m-items">—</dd>
        </div>
        <div class="flex justify-between gap-4">
          <dt class="text-gray-500">Order Ref</dt>
          <dd class="font-mono text-xs text-gray-600 text-right break-all" id="m-session">—</dd>
        </div>
      </dl>
    </div>
  </div>

  <Footer />
</Layout>

<script>
  // ── Balance ────────────────────────────────────────────────────────────────
  const fmt = (n: number) => `$${n.toFixed(2)}`;

  fetch('/api/seller/balance')
    .then(r => r.json())
    .then(d => {
      const avail = document.getElementById('bal-avail');
      const pend  = document.getElementById('bal-pending');
      if (avail) avail.textContent = d.available != null ? fmt(d.available) : '—';
      if (pend)  pend.textContent  = d.pending   != null ? fmt(d.pending)   : '—';
    })
    .catch(() => {});

  // ── Withdraw ───────────────────────────────────────────────────────────────
  const wBtn = document.getElementById('withdraw-btn') as HTMLButtonElement | null;
  const wAmt = document.getElementById('withdraw-amt') as HTMLInputElement  | null;
  const wMsg = document.getElementById('withdraw-msg') as HTMLElement       | null;

  wBtn?.addEventListener('click', async () => {
    const amount = parseFloat(wAmt?.value ?? '');
    if (!amount || amount <= 0) { if (wMsg) { wMsg.textContent = 'Enter a valid amount.'; wMsg.classList.remove('hidden'); } return; }
    wBtn.disabled = true;
    if (wMsg) { wMsg.textContent = 'Processing…'; wMsg.classList.remove('hidden'); }
    try {
      const res  = await fetch('/api/seller/withdraw', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ amount }) });
      const data = await res.json();
      if (!res.ok) throw new Error(data.error || 'Failed');
      if (wMsg) wMsg.textContent = `Payout initiated (${data.status}). Funds arrive in 1–4 business days.`;
      if (wAmt) wAmt.value = '';
    } catch (e: any) {
      if (wMsg) wMsg.textContent = e.message;
    } finally {
      wBtn.disabled = false;
    }
  });

  // ── Express Dashboard link ─────────────────────────────────────────────────
  document.getElementById('express-btn')?.addEventListener('click', async () => {
    const btn = document.getElementById('express-btn') as HTMLButtonElement;
    btn.textContent = 'Opening…';
    btn.setAttribute('disabled', 'true');
    try {
      const res  = await fetch('/api/seller/express-link');
      const data = await res.json();
      if (data.url) window.location.href = data.url;
      else throw new Error('No URL returned');
    } catch {
      btn.textContent = 'Failed — try again';
      btn.removeAttribute('disabled');
    }
  });

  // ── Mark shipped ───────────────────────────────────────────────────────────
  document.querySelectorAll<HTMLButtonElement>('.ship-btn').forEach(btn => {
    btn.addEventListener('click', async () => {
      const id = btn.dataset.id!;
      btn.disabled = true;
      btn.textContent = 'Saving…';
      try {
        const res = await fetch(`/api/clickz/${id}/ship`, { method: 'PATCH' });
        if (!res.ok) throw new Error();
        // Update row UI
        const row = btn.closest('.order-row') as HTMLElement;
        row.classList.add('opacity-40');
        row.dataset.shipped = 'true';
        const dot = row.querySelector('div.rounded-full') as HTMLElement;
        if (dot) { dot.classList.remove('bg-amber-400','animate-pulse'); dot.classList.add('bg-green-400'); }
        btn.replaceWith((() => {
          const s = document.createElement('span');
          s.className = 'text-xs text-green-600 font-semibold flex items-center gap-1';
          s.innerHTML = `<svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>Shipped`;
          return s;
        })());
      } catch {
        btn.disabled = false;
        btn.textContent = 'Mark Shipped';
        alert('Failed to update — try again.');
      }
    });
  });

  // ── Buyer details modal ────────────────────────────────────────────────────
  const modal   = document.getElementById('modal')!;
  const mClose  = document.getElementById('modal-close')!;
  const mName   = document.getElementById('m-name')!;
  const mEmail  = document.getElementById('m-email')!;
  const mItems  = document.getElementById('m-items')!;
  const mSess   = document.getElementById('m-session')!;

  document.querySelectorAll<HTMLButtonElement>('.details-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      mName.textContent  = btn.dataset.name    || '—';
      mEmail.textContent = btn.dataset.email   || '—';
      mItems.textContent = btn.dataset.items   || '—';
      mSess.textContent  = btn.dataset.session || '—';
      modal.classList.remove('hidden');
      modal.classList.add('flex');
    });
  });

  mClose.addEventListener('click', () => { modal.classList.add('hidden'); modal.classList.remove('flex'); });
  modal.addEventListener('click', e => { if (e.target === modal) { modal.classList.add('hidden'); modal.classList.remove('flex'); } });
</script>
