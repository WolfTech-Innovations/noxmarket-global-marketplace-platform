  const statusText = document.getElementById('status-text') as HTMLElement;
  const progressFill = document.getElementById('progress-fill') as HTMLElement;
  const thumbFile  = document.getElementById('thumb-file') as HTMLInputElement;
  const thumbPrev  = document.getElementById('thumb-preview') as HTMLImageElement;
  const thumbZone  = document.getElementById('thumb-zone') as HTMLElement;

  let videoBlob: File | null = null;
  let thumbBlob: File | null = null;

  function setProgress(pct: number, text: string) {
    progressFill.style.width = pct + '%';
    statusText.textContent = text;
  }

  function showStatus(type: 'loading'|'success'|'error', msg: string) {
