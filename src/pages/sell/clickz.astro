---
import Layout from '@/layouts/Layout.astro';
import { getSessionFromCookies } from '@/lib/auth';

const session = getSessionFromCookies(Astro.cookies);
if (!session) return Astro.redirect('/login?redirect=/sell/clickz');

const sellerName: string = session.businessName || session.name || 'User';
const sellerId: string = session.sellerId || session.userId;
const isModerator: boolean = session.sellerId === 'seller-nkbvjl-xak';
const bucketSlug: string = import.meta.env.COSMIC_BUCKET_SLUG;
const writeKey: string   = import.meta.env.COSMIC_WRITE_KEY;
const readKey: string    = import.meta.env.COSMIC_READ_KEY;
---

<Layout title="Post a Clickz — Nox">
<style>
  @import url('https://fonts.googleapis.com/css2?family=Syne:wght@800&family=DM+Sans:wght@400;500&display=swap');
  *{box-sizing:border-box;margin:0;padding:0}
  body{background:#0a0a0a;color:#fff;font-family:'DM Sans',sans-serif;min-height:100dvh}
  nav{display:flex;align-items:center;justify-content:space-between;padding:14px 20px;border-bottom:1px solid rgba(255,255,255,0.07);position:sticky;top:0;background:rgba(10,10,10,0.95);backdrop-filter:blur(12px);z-index:50}
  .logo{display:flex;align-items:center;gap:7px;font-family:'Syne',sans-serif;font-weight:800;font-size:1rem;color:#fff;text-decoration:none}
  .wrap{max-width:440px;margin:0 auto;padding:28px 16px 60px}
  .head{display:flex;align-items:baseline;justify-content:space-between;margin-bottom:20px}
  .head h1{font-family:'Syne',sans-serif;font-size:1.4rem;font-weight:800}
  .head h1 span{background:linear-gradient(135deg,#3b82f6,#6366f1);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
  .as{font-size:0.72rem;color:rgba(255,255,255,0.3)}
  .toggle{display:flex;gap:5px;margin-bottom:16px}
  .tbtn{flex:1;padding:8px;border-radius:8px;border:1px solid rgba(255,255,255,0.09);background:transparent;color:rgba(255,255,255,0.35);font-family:'DM Sans',sans-serif;font-size:0.8rem;cursor:pointer;transition:all 0.15s}
  .tbtn.on{background:rgba(59,130,246,0.1);border-color:rgba(59,130,246,0.3);color:#93c5fd}
  #drop{border:1.5px dashed rgba(255,255,255,0.1);border-radius:12px;padding:28px 16px;text-align:center;cursor:pointer;position:relative;margin-bottom:16px;transition:border-color 0.15s}
  #drop:hover,#drop.drag{border-color:rgba(59,130,246,0.45)}
  #drop p{font-size:0.75rem;color:rgba(255,255,255,0.3);margin-top:5px}
  #vfile{position:absolute;inset:0;opacity:0;cursor:pointer;width:100%;height:100%}
  #prev{display:none;position:relative;border-radius:12px;overflow:hidden;margin-bottom:16px;aspect-ratio:9/16;background:#111;max-height:360px}
  #pvid{width:100%;height:100%;object-fit:cover}
  .badge{position:absolute;top:8px;left:8px;background:rgba(0,0,0,0.55);backdrop-filter:blur(6px);border-radius:5px;padding:2px 7px;font-size:0.68rem;color:rgba(255,255,255,0.55)}
  #timer{position:absolute;bottom:8px;right:8px;background:rgba(0,0,0,0.65);border-radius:5px;padding:2px 7px;font-family:'Syne',sans-serif;font-weight:800;font-size:0.72rem}
  #timer.over{color:#f87171}#timer.ok{color:#4ade80}
  .chg{position:absolute;top:8px;right:8px;background:rgba(0,0,0,0.55);border:1px solid rgba(255,255,255,0.1);border-radius:5px;padding:3px 8px;font-size:0.68rem;color:#fff;cursor:pointer}
  .f{margin-bottom:12px}
  label{display:block;font-size:0.7rem;color:rgba(255,255,255,0.35);margin-bottom:5px;text-transform:uppercase;letter-spacing:0.04em}
  input,select,textarea{width:100%;background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.08);border-radius:9px;padding:10px 12px;color:#fff;font-family:'DM Sans',sans-serif;font-size:0.88rem;outline:none;transition:border-color 0.15s;-webkit-appearance:none}
  input:focus,select:focus,textarea:focus{border-color:rgba(59,130,246,0.4)}
  select option{background:#1a1a1a}
  textarea{resize:vertical;min-height:64px}
  .row{display:grid;grid-template-columns:1fr 1fr;gap:8px}
  #pfields.off{display:none}
  #submit{width:100%;background:linear-gradient(135deg,#3b82f6,#6366f1);color:#fff;border:none;border-radius:10px;padding:13px;font-family:'Syne',sans-serif;font-weight:800;font-size:0.92rem;cursor:pointer;margin-top:4px;transition:opacity 0.15s,transform 0.1s}
  #submit:disabled{opacity:0.3;cursor:not-allowed}
  #submit:not(:disabled):active{transform:scale(0.98)}
  #sbar{display:none;align-items:center;gap:8px;border-radius:9px;padding:10px 12px;margin-top:10px;font-size:0.8rem;color:rgba(255,255,255,0.55);background:rgba(255,255,255,0.04)}
  #sbar.on{display:flex}
  #sbar.ok{background:rgba(74,222,128,0.07);color:#4ade80;border:1px solid rgba(74,222,128,0.12)}
  #sbar.err{background:rgba(248,113,113,0.07);color:#f87171;border:1px solid rgba(248,113,113,0.12)}
  .bar{height:3px;background:rgba(255,255,255,0.06);border-radius:3px;overflow:hidden;flex:1}
  .fill{height:100%;background:linear-gradient(to right,#3b82f6,#6366f1);width:0%;transition:width 0.3s}
  #mod{margin-top:16px;background:rgba(251,191,36,0.04);border:1px solid rgba(251,191,36,0.12);border-radius:10px;padding:12px}
  .mh{display:flex;align-items:center;gap:6px;margin-bottom:10px;font-family:'Syne',sans-serif;font-weight:800;font-size:0.7rem;color:#fbbf24;letter-spacing:0.06em;text-transform:uppercase}
  #mod label{color:rgba(251,191,36,0.45)}
  #mod input,#mod select,#mod textarea{border-color:rgba(251,191,36,0.12)}
  #manage{margin-top:28px;border-top:1px solid rgba(255,255,255,0.06);padding-top:20px}
  #manage h2{font-family:'Syne',sans-serif;font-size:0.9rem;font-weight:800;margin-bottom:14px;color:rgba(255,255,255,0.55);letter-spacing:0.04em;text-transform:uppercase}
  .mcard{display:flex;align-items:center;gap:10px;background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.07);border-radius:10px;padding:10px 12px;margin-bottom:8px}
  .mthumb{width:38px;height:38px;border-radius:6px;object-fit:cover;background:#111;flex-shrink:0}
  .minfo{flex:1;min-width:0}
  .mtitle{font-size:0.82rem;font-weight:500;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
  .mmeta{font-size:0.68rem;color:rgba(255,255,255,0.3);margin-top:2px}
  .mdel{background:rgba(248,113,113,0.08);border:1px solid rgba(248,113,113,0.18);color:#f87171;border-radius:7px;padding:5px 11px;font-size:0.72rem;cursor:pointer;white-space:nowrap;transition:background 0.15s}
  .mdel:hover{background:rgba(248,113,113,0.18)}
  .mdel:disabled{opacity:0.4;cursor:not-allowed}
  #mload{font-size:0.75rem;color:rgba(255,255,255,0.25);text-align:center;padding:12px 0}
  .vtag{display:inline-block;font-size:0.6rem;background:rgba(99,102,241,0.15);color:#818cf8;border-radius:4px;padding:1px 5px;margin-left:5px;vertical-align:middle}
</style>

<nav>
  <a href="/" class="logo">
    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
    Nox
  </a>
  <a href="/clickz" style="color:rgba(255,255,255,0.3);font-size:0.78rem;text-decoration:none">Feed →</a>
</nav>

<div class="wrap">
  <div class="head">
    <h1>Post a <span>Clickz</span></h1>
    <span class="as">{sellerName}</span>
  </div>

  <div class="toggle">
    <button class="tbtn on" id="mode-listing">🛒 Listing</button>
    <button class="tbtn" id="mode-video">🎬 Video</button>
  </div>

  <div id="drop">
    <input type="file" id="vfile" accept="video/*,.gif" />
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,0.25)" stroke-width="2"><polygon points="23 7 16 12 23 17 23 7"/><rect x="1" y="5" width="15" height="14" rx="2" ry="2"/></svg>
    <p>MP4 · MOV · WebM · GIF · max 50MB</p>
  </div>

  <div id="prev">
    <video id="pvid" playsinline muted autoplay loop></video>
    <div class="badge">Preview</div>
    <div id="timer">—s</div>
    <button class="chg" id="chg">Change</button>
  </div>

  <div class="f"><label id="ltitle">Part Name</label><input id="ftitle" placeholder="e.g. ASUS RTX 4080 Super OC" /></div>

  <div id="pfields">
    <div class="row">
      <div class="f"><label>Category</label><select id="fcat"><option value="">Select…</option><option>Graphics Cards</option><option>Processors</option><option>Motherboards</option><option>Memory (RAM)</option><option>Storage</option><option>Power Supplies</option><option>Cooling</option><option>Cases</option><option>Other</option></select></div>
      <div class="f"><label>Price (USD)</label><input type="number" id="fprice" placeholder="299" min="1" /></div>
    </div>
    <div class="f"><label>Listing Slug</label><input id="fslug" placeholder="asus-rtx-4080-super" /></div>
  </div>

  <div class="f"><label>Description</label><textarea id="fdesc" placeholder="Condition, specs, why you're selling…"></textarea></div>

  <button id="submit" disabled>Post Clickz</button>

  <div id="sbar"><span id="stxt">Uploading…</span><div class="bar"><div class="fill" id="fill"></div></div></div>

  {isModerator && (
    <div id="mod">
      <div class="mh"><svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="#fbbf24" stroke-width="2.5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>Mod</div>
      <div class="row" style="margin-bottom:8px">
        <div class="f"><label>Status</label><select id="mstat"><option value="published">Published</option><option value="draft">Draft</option><option value="flagged">Flagged</option><option value="removed">Removed</option></select></div>
        <div class="f"><label>Override Seller ID</label><input id="msid" placeholder="session ID" /></div>
      </div>
      <div class="f"><label>Note</label><textarea id="mnote" placeholder="Internal note…" style="min-height:48px"></textarea></div>
    </div>
  )}

  <div id="manage">
    <h2>My Clickz <span id="mcount" style="font-size:0.7rem;color:rgba(255,255,255,0.25);font-family:'DM Sans',sans-serif;text-transform:none;font-weight:400"></span></h2>
    <div id="mload">Loading your Clickz…</div>
    <div id="mlist"></div>
  </div>
</div>
</Layout>

<script define:vars={{ bucketSlug, writeKey, readKey, sellerName, sellerId, isModerator }} is:inline>
  window.__C__ = {s:bucketSlug, w:writeKey, r:readKey, n:sellerName, i:sellerId, m:isModerator};
</script>

<script is:inline>
  const {s:BUCKET, w:KEY, n:SNAME, i:SID, m:IS_MOD} = window.__C__;
  console.log('[Clickz] SID:', SID);

  const $ = id => document.getElementById(id);

  const drop = $('drop'), vfile = $('vfile'), prev = $('prev'), pvid = $('pvid');
  const timer = $('timer'), submit = $('submit'), sbar = $('sbar'), stxt = $('stxt'), fill = $('fill');
  let vblob = null, listing = true;

  $('mode-listing').onclick = () => { listing = true; $('mode-listing').classList.add('on'); $('mode-video').classList.remove('on'); $('pfields').classList.remove('off'); $('ltitle').textContent = 'Part Name'; $('fdesc').placeholder = "Condition, specs, why you're selling…"; chk(); };
  $('mode-video').onclick = () => { listing = false; $('mode-video').classList.add('on'); $('mode-listing').classList.remove('on'); $('pfields').classList.add('off'); $('ltitle').textContent = 'Title'; $('fdesc').placeholder = "What’s this video about?"; chk(); };

  drop.addEventListener('dragover', e => { e.preventDefault(); drop.classList.add('drag'); });
  drop.addEventListener('dragleave', () => drop.classList.remove('drag'));
  drop.addEventListener('drop', e => { e.preventDefault(); drop.classList.remove('drag'); const f = e.dataTransfer?.files[0]; if (f && (f.type.startsWith('video/') || f.type === 'image/gif')) load(f); });
  vfile.addEventListener('change', () => { const f = vfile.files?.[0]; if (f) load(f); });

  function load(file) {
    vblob = file;
    if (file.type === 'image/gif') {
      const img = document.createElement('img');
      img.src = URL.createObjectURL(file);
      img.style.cssText = 'width:100%;height:100%;object-fit:cover';
      prev.innerHTML = '';
      prev.appendChild(img);
      prev.insertAdjacentHTML('beforeend', '<div class="badge">GIF</div><button class="chg" id="chg">Change</button>');
      $('chg').onclick = reset;
    } else {
      pvid.src = URL.createObjectURL(file);
      pvid.addEventListener('loadedmetadata', () => {
        const d = pvid.duration;
        timer.textContent = d.toFixed(1) + 's';
        timer.className = d > 8.5 ? 'over' : 'ok';
      }, {once: true});
    }
    drop.style.display = 'none';
    prev.style.display = 'block';
    chk();
  }

  function reset() {
    vblob = null;
    pvid.src = '';
    prev.style.display = 'none';
    drop.style.display = 'block';
    vfile.value = '';
    chk();
  }
  $('chg').onclick = reset;

  const lreq = ['ftitle','fcat','fprice','fslug'], vreq = ['ftitle'];
  lreq.forEach(id => { const el = $(id); if (el) el.addEventListener('input', chk); });

  function chk() {
    const req = listing ? lreq : vreq;
    submit.disabled = !vblob || !req.every(id => { const el = $(id); return el && el.value.trim(); });
  }

  // FIXED: Correct Cosmic v3 upload endpoint
  async function up(file, lbl) {
    const fd = new FormData();
    fd.append('media', file);
    const r = await fetch(`https://workers.cosmicjs.com/v3/buckets/${BUCKET}/media`, {
      method: 'POST',
      headers: { Authorization: `Bearer ${KEY}` },
      body: fd
    });
    const text = await r.text();
    let json = {};
    try { json = JSON.parse(text); } catch {}
    if (!r.ok) throw new Error(json.message || text || `Failed ${lbl}`);
    const m = json.media || json;
    if (!m?.url) throw new Error(`Upload succeeded but no media returned for ${lbl}`);
    return {name: m.name || '', url: m.url, imgix_url: m.imgix_url || m.url};
  }

  function thumb() {
    return new Promise(res => {
      const c = document.createElement('canvas');
      c.width = pvid.videoWidth || 1280;
      c.height = pvid.videoHeight || 720;
      c.getContext('2d').drawImage(pvid, 0, 0);
      c.toBlob(b => res(b), 'image/jpeg', 0.85);
    });
  }

  const prog = (p, t) => { if (fill) fill.style.width = p + '%'; stxt.textContent = t; };
  const stat = (type, msg) => {
    if (sbar) sbar.className = 'on ' + (type === 'l' ? '' : type === 'ok' ? 'ok' : 'err');
    stxt.textContent = msg;
    if (type !== 'l' && fill) fill.style.width = '100%';
  };
  const g = id => { const el = $(id); return el ? el.value.trim() : ''; };

  submit.onclick = async () => {
    if (!vblob) return;
    submit.disabled = true;
    if (sbar) sbar.className = 'on';
    prog(5, 'Starting…');

    try {
      prog(20, 'Uploading video…');
      const vu = await up(vblob, 'video');

      prog(50, 'Thumbnail…');
      const tu = await up(new File([await thumb()], 't.jpg', {type: 'image/jpeg'}), 'thumb');

      prog(75, 'Posting…');

      const slug = listing ? g('fslug') : (g('ftitle').toLowerCase().replace(/\s+/g,'-').replace(/[^a-z0-9-]/g,'') + '-' + Date.now());
      const ms = IS_MOD ? (g('mstat') || 'published') : 'published';

      const r = await fetch(`https://api.cosmicjs.com/v3/buckets/${BUCKET}/objects`, {
        method: 'POST',
        headers: {'Content-Type':'application/json', Authorization: `Bearer ${KEY}`},
        body: JSON.stringify({title:g('ftitle'),type:'clickz',slug,status:ms,metadata:{
          video:{name:vu.name,url:vu.url,imgix_url:vu.imgix_url},
          thumbnail:{name:tu.name,url:tu.url,imgix_url:tu.imgix_url},
          post_type: listing?'listing':'video',
          ...(listing?{category:g('fcat'),price:parseFloat(g('fprice')),listing_slug:g('fslug')}:{ }),
          seller_name:SNAME, seller_id:(IS_MOD&&g('msid'))||SID, description:g('fdesc'), likes:0,
          ...(IS_MOD&&g('mnote')?{mod_note:g('mnote')}:{ }),
          ...(IS_MOD?{moderated_by:SID}:{ })
        }})
      });

      if (!r.ok) throw new Error((await r.json().catch(() => ({}))).message || 'Failed');

      prog(100, '');
      stat('ok', 'Posted — redirecting…');
      setTimeout(() => { window.location.href = '/clickz'; }, 1500);
    } catch (e) {
      console.error(e);
      stat('err', e.message || 'Something went wrong');
      submit.disabled = false;
    }
  };

  // My Clickz manager (clean version)
  const {r:RKEY} = window.__C__;

  async function loadMyClickz() {
    const mlist = $('mlist'), mload = $('mload'), mcount = $('mcount');
    if (mload) mload.style.display = 'block';
    if (!SID) {
      if (mload) mload.textContent = 'Account error';
      return;
    }

    const query = JSON.stringify({type:'clickz','metadata.seller_id':SID});
    const url = `https://api.cosmicjs.com/v3/buckets/\( {BUCKET}/objects?query= \){encodeURIComponent(query)}&props=id,title,metadata.thumbnail,metadata.post_type,metadata.price,metadata.category&limit=100&status=any`;

    let items = [];
    try {
      const res = await fetch(url, {headers: {Authorization: `Bearer ${RKEY}`}});
      items = (await res.json()).objects || [];
    } catch (e) { console.error(e); }

    if (mload) mload.style.display = 'none';
    if (mcount) mcount.textContent = items.length ? `(${items.length})` : '';

    if (!items.length) {
      if (mload) {
        mload.textContent = 'No Clickz yet';
        mload.style.display = 'block';
      }
      return;
    }

    if (mlist) mlist.innerHTML = '';
    items.forEach(obj => {
      const thumb = obj.metadata?.thumbnail?.imgix_url ? obj.metadata.thumbnail.imgix_url + '?w=80&h=80&fit=crop&auto=format' : '';
      const isVid = obj.metadata?.post_type === 'video';
      const sub = isVid ? 'Video' : [obj.metadata?.category, obj.metadata?.price != null ? `$${obj.metadata.price}` : ''].filter(Boolean).join(' · ');

      const card = document.createElement('div');
      card.className = 'mcard';
      card.innerHTML = `
        \( {thumb ? `<img class="mthumb" src=" \){thumb}" loading="lazy" />` : '<div class="mthumb"></div>'}
        <div class="minfo">
          <div class="mtitle">\( {obj.title} \){isVid ? '<span class="vtag">video</span>' : ''}</div>
          \( {sub ? `<div class="mmeta"> \){sub}</div>` : ''}
        </div>
        <button class="mdel" data-id="${obj.id}">Delete</button>
      `;

      const btn = card.querySelector('.mdel');
      if (btn) btn.onclick = () => deleteClickz(obj.id, obj.title, card, btn);
      if (mlist) mlist.appendChild(card);
    });
  }

  async function deleteClickz(id, title, card, btn) {
    if (!confirm(`Delete "${title}"?\nThis cannot be undone.`)) return;
    btn.disabled = true;
    btn.textContent = 'Deleting…';
    try {
      const res = await fetch(`/api/clickz/${id}`, {method: 'DELETE'});
      if (!res.ok) throw new Error('Delete failed');
      card.style.opacity = '0';
      card.style.transform = 'scale(0.96)';
      card.style.transition = 'all 0.25s';
      setTimeout(() => card.remove(), 300);
    } catch (e) {
      btn.disabled = false;
      btn.textContent = 'Delete';
      alert('Delete failed');
    }
  }

  loadMyClickz();
</script>