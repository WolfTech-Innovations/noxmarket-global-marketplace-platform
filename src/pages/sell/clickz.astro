<script define:vars={{ bucketSlug, writeKey, readKey, sellerName, sellerId, isModerator }} is:inline>
  window.__C__={s:bucketSlug,w:writeKey,r:readKey,n:sellerName,i:sellerId,m:isModerator};
</script>

<script>
const {s:B,w:K,n:N,i:S,m:M}=(window as any).__C__, $=id=>document.getElementById(id)!;
const drop=\( ('drop'),vf= \)('vfile')as HTMLInputElement,pr=\( ('prev'),pv= \)('pvid')as HTMLVideoElement;
const tm=\( ('timer'),sb= \)('submit')as HTMLButtonElement,bar=\( ('sbar'),st= \)('stxt'),fl=$('fill');
let file=null, isList=true;

const ml=\( ('mode-listing')as HTMLButtonElement, mv= \)('mode-video')as HTMLButtonElement;
const pf=\( ('pfields'), lt= \)('ltitle'), desc=$('fdesc')as HTMLTextAreaElement;

ml.onclick=()=>{isList=true;ml.classList.add('on');mv.classList.remove('on');pf.classList.remove('off');lt.textContent='Part Name';desc.placeholder="Condition, specs...";chk()};
mv.onclick=()=>{isList=false;mv.classList.add('on');ml.classList.remove('on');pf.classList.add('off');lt.textContent='Title';desc.placeholder="What’s this video about?";chk()};

drop.ondragover=e=>{e.preventDefault();drop.classList.add('drag')};
drop.ondragleave=()=>drop.classList.remove('drag');
drop.ondrop=e=>{e.preventDefault();drop.classList.remove('drag');const f=e.dataTransfer?.files[0];if(f&&(f.type.startsWith('video/')||f.type==='image/gif'))load(f)};
vf.onchange=()=>{const f=vf.files?.[0];if(f)load(f)};

function load(f){file=f;
  if(f.type==='image/gif'){
    const i=document.createElement('img');i.src=URL.createObjectURL(f);i.style.cssText='width:100%;height:100%;object-fit:cover';
    pr.innerHTML='';pr.append(i,document.createRange().createContextualFragment('<div class="badge">GIF</div><button class="chg" id="chg">Change</button>'));
    ($('chg')as HTMLButtonElement).onclick=reset;
  }else{
    pv.src=URL.createObjectURL(f);pv.onloadedmetadata=()=>{const d=pv.duration;tm.textContent=d.toFixed(1)+'s';tm.className=d>8.5?'over':'ok'};
  }
  drop.style.display='none';pr.style.display='block';chk();
}
function reset(){file=null;pv.src='';pr.style.display='none';drop.style.display='block';vf.value='';chk()}
$('chg').onclick=reset;

const lreq=['ftitle','fcat','fprice','fslug'], vreq=['ftitle'];
lreq.forEach(id=>$(id).addEventListener('input',chk));
function chk(){sb.disabled=!file||!(isList?lreq:vreq).every(id=>($(id)as HTMLInputElement).value.trim())}

async function upload(f,lbl){
  const fd=new FormData();fd.append('media',f);
  const r=await fetch(`https://workers.cosmicjs.com/v3/buckets/${B}/media`,{method:'POST',headers:{Authorization:`Bearer ${K}`},body:fd});
  const t=await r.text(), j=JSON.parse(t)||{};
  if(!r.ok)throw new Error(j.message||t||`Failed ${lbl}`);
  const m=j.media||j;
  if(!m?.url)throw new Error(`No URL for ${lbl}`);
  return {name:m.name||'',url:m.url,imgix_url:m.imgix_url||m.url};
}

function thumb(){return new Promise(r=>{const c=document.createElement('canvas');c.width=pv.videoWidth;c.height=pv.videoHeight;c.getContext('2d')!.drawImage(pv,0,0);c.toBlob(b=>r(b!),'image/jpeg',0.85)})}

const prog=(p,t)=>{fl.style.width=p+'%';st.textContent=t};
const stat=(t,m)=>{bar.className='on '+(t==='l'?'':t==='ok'?'ok':'err');st.textContent=m;if(t!=='l')fl.style.width='100%'};
const g=id=>($(id)as any).value.trim();

sb.onclick=async()=>{
  if(!file)return; sb.disabled=true; bar.className='on'; prog(5,'Starting...');
  try{
    prog(20,'Uploading video...');const vu=await upload(file,'video');
    prog(50,'Thumbnail...');const tu=await upload(new File([await thumb()],'t.jpg',{type:'image/jpeg'}),'thumb');
    prog(75,'Posting...');

    const slug=isList?g('fslug'):(g('ftitle').toLowerCase().replace(/\s+/g,'-').replace(/[^a-z0-9-]/g,'')+'-'+Date.now());
    const status=M?(g('mstat')||'published'):'published';

    const res=await fetch(`https://api.cosmicjs.com/v3/buckets/${B}/objects`,{
      method:'POST',
      headers:{'Content-Type':'application/json',Authorization:`Bearer ${K}`},
      body:JSON.stringify({title:g('ftitle'),type:'clickz',slug,status,metadata:{
        video:{name:vu.name,url:vu.url,imgix_url:vu.imgix_url},
        thumbnail:{name:tu.name,url:tu.url,imgix_url:tu.imgix_url},
        post_type:isList?'listing':'video',
        ...(isList?{category:g('fcat'),price:parseFloat(g('fprice')),listing_slug:g('fslug')}:{ }),
        seller_name:N,seller_id:(M&&g('msid'))||S,description:g('fdesc'),likes:0,
        ...(M&&g('mnote')?{mod_note:g('mnote')}:{ }),
        ...(M?{moderated_by:S}:{ })
      }})
    });
    if(!res.ok)throw new Error((await res.json()).message||'Post failed');

    prog(100,'');stat('ok','Posted — redirecting...');
    setTimeout(()=>location.href='/clickz',1500);
  }catch(e:any){console.error(e);stat('err',e.message||'Error');sb.disabled=false}
};

// My Clickz manager (condensed)
const {r:R}=(window as any).__C__;
async function loadMy(){
  const list=\( ('mlist'), load= \)('mload'), count=$('mcount');
  load.style.display='block';
  if(!S){load.textContent='Account error';return}

  const q=JSON.stringify({type:'clickz','metadata.seller_id':S});
  const url=`https://api.cosmicjs.com/v3/buckets/\( {B}/objects?query= \){encodeURIComponent(q)}&props=id,title,metadata.thumbnail,metadata.post_type,metadata.price,metadata.category&limit=100&status=any`;

  let items=[];
  try{items=(await (await fetch(url,{headers:{Authorization:`Bearer ${R}`}})).json()).objects||[]}catch{}

  load.style.display='none';count.textContent=items.length?`(${items.length})`:'';

  if(!items.length){load.textContent='No Clickz yet';load.style.display='block';return}

  list.innerHTML='';
  items.forEach(o=>{
    const thumb=o.metadata?.thumbnail?.imgix_url? o.metadata.thumbnail.imgix_url+'?w=80&h=80&fit=crop&auto=format' : '';
    const isVid=o.metadata?.post_type==='video';
    const sub=isVid?'Video':[o.metadata?.category,o.metadata?.price!=null?`$${o.metadata.price}`:''].filter(Boolean).join(' · ');

    const card=document.createElement('div');card.className='mcard';
    card.innerHTML=`
      \( {thumb?`<img class="mthumb" src=" \){thumb}" loading="lazy">`:'<div class="mthumb"></div>'}
      <div class="minfo"><div class="mtitle">\( {o.title} \){isVid?'<span class="vtag">video</span>':''}</div>\( {sub?`<div class="mmeta"> \){sub}</div>`:''}</div>
      <button class="mdel" data-id="${o.id}">Delete</button>
    `;
    (card.querySelector('.mdel')as HTMLButtonElement).onclick=()=>del(o.id,o.title,card);
    list.appendChild(card);
  });
}

async function del(id,title,card){
  if(!confirm(`Delete "${title}"?`))return;
  const btn=card.querySelector('.mdel')as HTMLButtonElement;
  btn.disabled=true;btn.textContent='Deleting...';
  try{
    const r=await fetch(`/api/clickz/${id}`,{method:'DELETE'});
    if(!r.ok)throw new Error((await r.json()).error||'Failed');
    card.style.transition='all .25s';card.style.opacity='0';card.style.transform='scale(.95)';
    setTimeout(()=>{card.remove();const c=\( ('mcount');let n=parseInt(c.textContent||'0');c.textContent=n>1?`( \){n-1})`:'';},300);
  }catch(e){btn.disabled=false;btn.textContent='Delete';alert(e.message||'Delete failed')}
}

loadMy();
</script>