  // Upload to Cosmic
  async function uploadMedia(file: File, label: string): Promise<string> {
    const formData = new FormData();
    formData.append('media', file);
    formData.append('write_key', WRITE_KEY);

    const res = await fetch(`https://api.cosmicjs.com/v3/buckets/${BUCKET_SLUG}/media`, {
