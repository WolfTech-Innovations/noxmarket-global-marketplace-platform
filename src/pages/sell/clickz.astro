---
import Layout from '@/layouts/Layout.astro';
import { getSessionFromCookies } from '@/lib/auth';
const s=getSessionFromCookies(Astro.cookies);
if(!s)return Astro.redirect('/login?redirect=/sell/clickz');
const sn:string=s.businessName||s.name||'User';
const si:string=s.sellerId||s.userId;
const im:boolean=s.sellerId==='seller-nkbvjl-xak';
---
<Layout title="Post a Clickz — Nox">
<style>
@import url('https://fonts.googleapis.com/css2?family=Syne:wght@800&family=DM+Sans:wght@400;500&display=swap');
*{box-sizing:border-box;margin:0;padding:0}
body{background:#0a0a0a;color:#fff;font-family:'DM Sans',sans-serif;min-height:100dvh}
nav{display:flex;align-items:center;justify-content:space-between;padding:14px 20px;border-bottom:1px solid rgba(255,255,255,.07);position:sticky;top:0;background:rgba(10,10,10,.95);backdrop-filter:blur(12px);z-index:50}
.logo{display:flex;align-items:center;gap:7px;font-family:'Syne',sans-serif;font-weight:800;font-size:1rem;color:#fff;text-decoration:none}
.wrap{max-width:440px;margin:0 auto;padding:28px 16px 60px}
.head{display:flex;align-items:baseline;justify-content:space-between;margin-bottom:20px}
.head h1{font-family:'Syne',sans-serif;font-size:1.4rem;font-weight:800}
.head h1 span{background:linear-gradient(135deg,#3b82f6,#6366f1);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
.as{font-size:.72rem;color:rgba(255,255,255,.3)}
.toggle{display:flex;gap:5px;margin-bottom:16px}
.tbtn{flex:1;padding:8px;border-radius:8px;border:1px solid rgba(255,255,255,.09);background:transparent;color:rgba(255,255,255,.35);font-family:'DM Sans',sans-serif;font-size:.8rem;cursor:pointer;transition:all .15s}
.tbtn.on{background:rgba(59,130,246,.1);border-color:rgba(59,130,246,.3);color:#93c5fd}
#drop{border:1.5px dashed rgba(255,255,255,.1);border-radius:12px;padding:28px 16px;text-align:center;cursor:pointer;position:relative;margin-bottom:16px;transition:border-color .15s}
#drop:hover,#drop.drag{border-color:rgba(59,130,246,.45)}
#drop p{font-size:.75rem;color:rgba(255,255,255,.3);margin-top:5px}
#vfile{position:absolute;inset:0;opacity:0;cursor:pointer;width:100%;height:100%}
#prev{display:none;position:relative;border-radius:12px;overflow:hidden;margin-bottom:16px;aspect-ratio:9/16;background:#111;max-height:360px}
#pvid{width:100%;height:100%;object-fit:cover}
.badge{position:absolute;top:8px;left:8px;background:rgba(0,0,0,.55);backdrop-filter:blur(6px);border-radius:5px;padding:2px 7px;font-size:.68rem;color:rgba(255,255,255,.55)}
#timer{position:absolute;bottom:8px;right:8px;background:rgba(0,0,0,.65);border-radius:5px;padding:2px 7px;font-family:'Syne',sans-serif;font-weight:800;font-size:.72rem}
#timer.over{color:#f87171}#timer.ok{color:#4ade80}
.chg{position:absolute;top:8px;right:8px;background:rgba(0,0,0,.55);border:1px solid rgba(255,255,255,.1);border-radius:5px;padding:3px 8px;font-size:.68rem;color:#fff;cursor:pointer}
.f{margin-bottom:12px}
label{display:block;font-size:.7rem;color:rgba(255,255,255,.35);margin-bottom:5px;text-transform:uppercase;letter-spacing:.04em}
input,select,textarea{width:100%;background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.08);border-radius:9px;padding:10px 12px;color:#fff;font-family:'DM Sans',sans-serif;font-size:.88rem;outline:none;transition:border-color .15s;-webkit-appearance:none}
input:focus,select:focus,textarea:focus{border-color:rgba(59,130,246,.4)}
select option{background:#1a1a1a}
textarea{resize:vertical;min-height:64px}
.row{display:grid;grid-template-columns:1fr 1fr;gap:8px}
#pfields.off{display:none}
#submit{width:100%;background:linear-gradient(135deg,#3b82f6,#6366f1);color:#fff;border:none;border-radius:10px;padding:13px;font-family:'Syne',sans-serif;font-weight:800;font-size:.92rem;cursor:pointer;margin-top:4px;transition:opacity .15s,transform .1s}
#submit:disabled{opacity:.3;cursor:not-allowed}
#submit:not(:disabled):active{transform:scale(.98)}
#sbar{display:none;align-items:center;gap:8px;border-radius:9px;padding:10px 12px;margin-top:10px;font-size:.8rem;color:rgba(255,255,255,.55);background:rgba(255,255,255,.04)}
#sbar.on{display:flex}
#sbar.ok{background:rgba(74,222,128,.07);color:#4ade80;border:1px solid rgba(74,222,128,.12)}
#sbar.err{background:rgba(248,113,113,.07);color:#f87171;border:1px solid rgba(248,113,113,.12)}
.bar{height:3px;background:rgba(255,255,255,.06);border-radius:3px;overflow:hidden;flex:1}
.fill{height:100%;background:linear-gradient(to right,#3b82f6,#6366f1);width:0%;transition:width .3s}
#mod{margin-top:16px;background:rgba(251,191,36,.04);border:1px solid rgba(251,191,36,.12);border-radius:10px;padding:12px}
.mh{display:flex;align-items:center;gap:6px;margin-bottom:10px;font-family:'Syne',sans-serif;font-weight:800;font-size:.7rem;color:#fbbf24;letter-spacing:.06em;text-transform:uppercase}
#mod label{color:rgba(251,191,36,.45)}
#mod input,#mod select,#mod textarea{border-color:rgba(251,191,36,.12)}
#manage{margin-top:28px;border-top:1px solid rgba(255,255,255,.06);padding-top:20px}
#manage h2{font-family:'Syne',sans-serif;font-size:.9rem;font-weight:800;margin-bottom:14px;color:rgba(255,255,255,.55);letter-spacing:.04em;text-transform:uppercase}
.mcard{display:flex;align-items:center;gap:10px;background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.07);border-radius:10px;padding:10px 12px;margin-bottom:8px}
.mthumb{width:38px;height:38px;border-radius:6px;object-fit:cover;background:#111;flex-shrink:0}
.minfo{flex:1;min-width:0}
.mtitle{font-size:.82rem;font-weight:500;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.mmeta{font-size:.68rem;color:rgba(255,255,255,.3);margin-top:2px}
.mdel{background:rgba(248,113,113,.08);border:1px solid rgba(248,113,113,.18);color:#f87171;border-radius:7px;padding:5px 11px;font-size:.72rem;cursor:pointer;white-space:nowrap;transition:background .15s}
.mdel:hover{background:rgba(248,113,113,.18)}
.mdel:disabled{opacity:.4;cursor:not-allowed}
#mload{font-size:.75rem;color:rgba(255,255,255,.25);text-align:center;padding:12px 0}
.vtag{display:inline-block;font-size:.6rem;background:rgba(99,102,241,.15);color:#818cf8;border-radius:4px;padding:1px 5px;margin-left:5px;vertical-align:middle}
</style>
<nav>
  <a href="/" class="logo"><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>Nox</a>
  <a href="/clickz" style="color:rgba(255,255,255,.3);font-size:.78rem;text-decoration:none">Feed →</a>
</nav>
<div class="wrap">
  <div class="head"><h1>Post a <span>Clickz</span></h1><span class="as">{sn}</span></div>
  <div class="toggle">
    <button class="tbtn on" id="ml">🛒 Listing</button>
    <button class="tbtn" id="mv">🎬 Video</button>
  </div>
  <div id="drop">
    <input type="file" id="vfile" accept="video/*,.gif"/>
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,.25)" stroke-width="2"><polygon points="23 7 16 12 23 17 23 7"/><rect x="1" y="5" width="15" height="14" rx="2" ry="2"/></svg>
    <p>MP4 · MOV · WebM · GIF · max 50MB</p>
  </div>
  <div id="prev">
    <video id="pvid" playsinline muted autoplay loop></video>
    <div class="badge">Preview</div>
    <div id="timer">—s</div>
    <button class="chg" id="chg">Change</button>
  </div>
  <div class="f"><label id="ltitle">Part Name</label><input id="ftitle" placeholder="e.g. ASUS RTX 4080 Super OC"/></div>
  <div id="pfields">
    <div class="row">
      <div class="f"><label>Category</label><select id="fcat"><option value="">Select…</option><option>Graphics Cards</option><option>Processors</option><option>Motherboards</option><option>Memory (RAM)</option><option>Storage</option><option>Power Supplies</option><option>Cooling</option><option>Cases</option><option>Other</option></select></div>
      <div class="f"><label>Price (USD)</label><input type="number" id="fprice" placeholder="299" min="1"/></div>
    </div>
    <div class="f"><label>Listing Slug</label><input id="fslug" placeholder="asus-rtx-4080-super"/></div>
  </div>
  <div class="f"><label>Description</label><textarea id="fdesc" placeholder="Condition, specs, why you're selling…"></textarea></div>
  <button id="submit" disabled>Post Clickz</button>
  <div id="sbar"><span id="stxt">Uploading…</span><div class="bar"><div class="fill" id="fill"></div></div></div>
  {im&&(<div id="mod"><div class="mh"><svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="#fbbf24" stroke-width="2.5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>Mod</div><div class="row" style="margin-bottom:8px"><div class="f"><label>Status</label><select id="mstat"><option value="published">Published</option><option value="draft">Draft</option><option value="flagged">Flagged</option><option value="removed">Removed</option></select></div><div class="f"><label>Override Seller ID</label><input id="msid" placeholder="session ID"/></div></div><div class="f"><label>Note</label><textarea id="mnote" placeholder="Internal note…" style="min-height:48px"></textarea></div></div>)}
  <div id="manage">
    <h2>My Clickz <span id="mc" style="font-size:.7rem;color:rgba(255,255,255,.25);font-family:'DM Sans',sans-serif;text-transform:none;font-weight:400"></span></h2>
    <div id="mload">Loading your Clickz…</div>
    <div id="mlist"></div>
  </div>
</div>
</Layout>
<script define:vars={{sn,si,im}} is:inline>
window.__C__={n:sn,i:si,m:im};
</script>
<script>
const {n:SN,i:SID,m:MOD}=(window as any).__C__;
const $=(id:string)=>document.getElementById(id)!;
const el={drop:$('drop'),vf:$('vfile') as HTMLInputElement,prev:$('prev'),pv:$('pvid') as HTMLVideoElement,tmr:$('timer'),sub:$('submit') as HTMLButtonElement,sb:$('sbar'),st:$('stxt'),fl:$('fill') as HTMLElement,pf:$('pfields'),lt:$('ltitle'),fd:$('fdesc') as HTMLTextAreaElement};
let blob:File|null=null,lst=true;
const g=(id:string)=>($(id) as HTMLInputElement|HTMLSelectElement|HTMLTextAreaElement).value.trim();
const chk=()=>{const r=lst?['ftitle','fcat','fprice','fslug']:['ftitle'];el.sub.disabled=!blob||!r.every(id=>g(id));};
const prog=(p:number,t:string)=>{el.fl.style.width=p+'%';el.st.textContent=t;};
const stat=(t:'l'|'ok'|'err',m:string)=>{el.sb.className='on '+(t==='l'?'':t==='ok'?'ok':'err');el.st.textContent=m;if(t!=='l')el.fl.style.width='100%';};
const rst=()=>{blob=null;el.pv.src='';el.prev.style.display='none';el.drop.style.display='block';el.vf.value='';chk();};
['ftitle','fcat','fprice','fslug'].forEach(id=>$(id)?.addEventListener('input',chk));
$('ml').onclick=()=>{lst=true;$('ml').classList.add('on');$('mv').classList.remove('on');el.pf.classList.remove('off');el.lt.textContent='Part Name';el.fd.placeholder="Condition, specs, why you're selling\u2026";chk();};
$('mv').onclick=()=>{lst=false;$('mv').classList.add('on');$('ml').classList.remove('on');el.pf.classList.add('off');el.lt.textContent='Title';el.fd.placeholder="What\u2019s this video about?";chk();};
$('chg').onclick=rst;
el.drop.addEventListener('dragover',e=>{e.preventDefault();el.drop.classList.add('drag');});
el.drop.addEventListener('dragleave',()=>el.drop.classList.remove('drag'));
el.drop.addEventListener('drop',e=>{e.preventDefault();el.drop.classList.remove('drag');const f=(e as DragEvent).dataTransfer?.files[0];if(f&&(f.type.startsWith('video/')||f.type==='image/gif'))load(f);});
el.vf.addEventListener('change',()=>{const f=el.vf.files?.[0];if(f)load(f);});
function load(f:File){
  blob=f;
  if(f.type==='image/gif'){
    const img=document.createElement('img');img.src=URL.createObjectURL(f);img.style.cssText='width:100%;height:100%;object-fit:cover';
    el.prev.innerHTML='';el.prev.appendChild(img);el.prev.insertAdjacentHTML('beforeend','<div class="badge">GIF</div><button class="chg" id="chg">Change</button>');
    $('chg').onclick=rst;
  }else{
    el.pv.src=URL.createObjectURL(f);
    el.pv.addEventListener('loadedmetadata',()=>{const d=el.pv.duration;el.tmr.textContent=d.toFixed(1)+'s';el.tmr.className=d>8.5?'over':'ok';el.pv.currentTime=Math.min(.5,d*.1);},{once:true});
  }
  el.drop.style.display='none';el.prev.style.display='block';chk();
}
async function up(f:File):Promise<{name:string;url:string;imgix_url:string}>{
  const fd=new FormData();fd.append('media',f);
  const r=await fetch('/api/clickz/upload',{method:'POST',body:fd,credentials:'include'});
  const j=await r.json();if(!r.ok)throw new Error(j.error||'Upload failed');
  return{name:j.name,url:j.url,imgix_url:j.imgix_url};
}
function snap():Promise<Blob>{
  return new Promise((res,rej)=>{
    const go=()=>{const c=document.createElement('canvas');c.width=el.pv.videoWidth;c.height=el.pv.videoHeight;if(!c.width||!c.height)return rej(new Error('not ready'));c.getContext('2d')!.drawImage(el.pv,0,0);c.toBlob(b=>b?res(b):rej(new Error('toBlob failed')),'image/jpeg',.85);};
    el.pv.readyState>=2&&el.pv.videoWidth>0?go():(el.pv.addEventListener('seeked',go,{once:true}),el.pv.currentTime=Math.min(.5,el.pv.duration*.1||.5));
  });
}
el.sub.onclick=async()=>{
  if(!blob)return;
  el.sub.disabled=true;el.sb.className='on';prog(5,'Starting\u2026');
  try{
    prog(15,'Uploading video\u2026');const vu=await up(blob);
    prog(50,'Thumbnail\u2026');const tu=blob.type==='image/gif'?vu:await up(new File([await snap()],'t.jpg',{type:'image/jpeg'}));
    prog(75,'Posting\u2026');
    const slug=lst?g('fslug'):g('ftitle').toLowerCase().replace(/\s+/g,'-').replace(/[^a-z0-9-]/g,'')+'-'+Date.now();
    if(!/^[a-z0-9]+(?:-[a-z0-9]+)*$/.test(slug))throw new Error('Invalid slug');
    const r=await fetch('/api/clickz/create',{method:'POST',headers:{'Content-Type':'application/json'},credentials:'include',body:JSON.stringify({
      title:g('ftitle'),slug,status:MOD?(($('mstat') as HTMLSelectElement)?.value??'published'):'published',
      post_type:lst?'listing':'video',category:lst?g('fcat'):undefined,price:lst?parseFloat(g('fprice')):undefined,
      listing_slug:lst?g('fslug'):undefined,description:g('fdesc'),seller_name:SN,seller_id:(MOD?g('msid'):'')||SID,
      video:vu,thumbnail:tu,mod_note:MOD?g('mnote'):undefined,moderated_by:MOD?SID:undefined
    })});
    if(!r.ok)throw new Error((await r.json()).error||'Failed');
    prog(100,'');stat('ok','Posted \u2014 redirecting\u2026');
    setTimeout(()=>{window.location.href='/clickz';},2000);
  }catch(e:any){stat('err',e.message||'Something went wrong');el.sub.disabled=false;}
};
interface CI{id:string;title:string;metadata:{thumbnail?:{imgix_url?:string};post_type?:string;price?:number;category?:string};}
async function loadMine(){
  const ml=$('mload') as HTMLElement,list=$('mlist') as HTMLElement,mc=$('mc') as HTMLElement;
  ml.style.display='block';
  if(!SID){ml.textContent='Could not identify account.';return;}
  let items:CI[]=[];
  try{const r=await fetch('/api/clickz/mine',{credentials:'include'});items=(await r.json()).objects??[];}catch{}
  ml.style.display='none';mc.textContent=items.length?`(${items.length})`:'';
  if(!items.length){ml.textContent='No Clickz posted yet.';ml.style.display='block';return;}
  list.innerHTML='';
  items.forEach(o=>{
    const th=o.metadata?.thumbnail?.imgix_url?o.metadata.thumbnail.imgix_url+'?w=80&h=80&fit=crop&auto=format':'';
    const iv=o.metadata?.post_type==='video';
    const sub=iv?'Video':[o.metadata?.category,o.metadata?.price!=null?`$${o.metadata.price}`:''].filter(Boolean).join(' · ');
    const card=document.createElement('div');card.className='mcard';
    card.innerHTML=`${th?`<img class="mthumb" src="${th}" alt="" loading="lazy"/>`:'<div class="mthumb"></div>'}<div class="minfo"><div class="mtitle">${o.title}${iv?'<span class="vtag">video</span>':''}</div>${sub?`<div class="mmeta">${sub}</div>`:''}</div><button class="mdel" data-id="${o.id}">Delete</button>`;
    (card.querySelector('.mdel') as HTMLButtonElement).onclick=()=>del(o.id,o.title,card);
    list.appendChild(card);
  });
}
async function del(id:string,title:string,card:HTMLElement){
  const btn=card.querySelector('.mdel') as HTMLButtonElement;
  if(!confirm(`Delete "${title}"?\nThis cannot be undone.`))return;
  btn.disabled=true;btn.textContent='Deleting…';
  try{
    const r=await fetch(`/api/clickz/${id}`,{method:'DELETE',credentials:'include'});
    const d=await r.json();if(!r.ok)throw new Error(d.error||'Delete failed');
    Object.assign(card.style,{opacity:'0',transform:'scale(.96)',transition:'opacity .25s,transform .25s'});
    setTimeout(()=>{card.remove();const mc=$('mc') as HTMLElement;const n=parseInt(mc.textContent?.replace(/\D/g,'')||'0');mc.textContent=n>1?`(${n-1})`:'';}  ,260);
  }catch(e:any){btn.disabled=false;btn.textContent='Delete';alert(e.message);}
}
loadMine();
</script>
