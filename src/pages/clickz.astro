---
import Layout from '@/layouts/Layout.astro';
import { getClickz } from '@/lib/cosmic';
import type { Clickz } from '@/types';
const C = await getClickz();
---
<Layout title="Clickz — Nox">
<style>
@import url('https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:wght@300;400;500&display=swap');
*{box-sizing:border-box;margin:0;padding:0}
body{background:#000;color:#fff;font-family:'DM Sans',sans-serif;overflow:hidden}

/* ── Desktop letterbox layout ── */
#shell{position:fixed;inset:0;display:flex;align-items:stretch}

/* Left sidebar */
#SL{flex:1;background:#0a0a0a;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:32px;padding:24px 16px;border-right:1px solid rgba(255,255,255,.06)}
#SL .logo{display:flex;flex-direction:column;align-items:center;gap:6px;font-family:'Syne',sans-serif;font-weight:800;font-size:1.1rem;letter-spacing:-.02em;color:#fff;text-decoration:none}
#SL .logo svg{width:28px;height:28px}
.snav{display:flex;flex-direction:column;gap:4px;width:100%}
.snav a{display:flex;flex-direction:column;align-items:center;gap:4px;padding:10px 8px;border-radius:10px;color:rgba(255,255,255,.5);text-decoration:none;font-size:.62rem;font-weight:500;letter-spacing:.04em;transition:background .15s,color .15s}
.snav a:hover,.snav a.active{background:rgba(255,255,255,.07);color:#fff}
.snav a svg{width:20px;height:20px}
.snav a.active svg{stroke:#3b82f6}
.sl-bottom{margin-top:auto;display:flex;flex-direction:column;align-items:center;gap:10px}
.sl-post{background:linear-gradient(135deg,#3b82f6,#6366f1);color:#fff;border:none;border-radius:10px;padding:8px 12px;font-family:'Syne',sans-serif;font-weight:700;font-size:.7rem;cursor:pointer;text-decoration:none;text-align:center;letter-spacing:.04em}

/* Center feed column — 9:16 aspect ratio capped at viewport height */
#FC{flex:none;width:calc(100dvh * 9/16);max-width:480px;min-width:320px;position:relative;overflow:hidden}

/* Right sidebar */
#SR{flex:1;background:#0a0a0a;display:flex;flex-direction:column;padding:24px 16px;gap:20px;border-left:1px solid rgba(255,255,255,.06);overflow:hidden}
.sr-title{font-family:'Syne',sans-serif;font-weight:700;font-size:.75rem;color:rgba(255,255,255,.35);letter-spacing:.08em;text-transform:uppercase}
.sr-card{background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.07);border-radius:12px;padding:14px;display:flex;flex-direction:column;gap:6px}
.sr-card-label{font-size:.65rem;color:rgba(255,255,255,.4);font-weight:500}
.sr-card-value{font-family:'Syne',sans-serif;font-weight:700;font-size:1.1rem;color:#fff}
.sr-card-sub{font-size:.7rem;color:rgba(255,255,255,.45)}
.sr-divider{height:1px;background:rgba(255,255,255,.06);margin:4px 0}
.sr-tag{display:inline-flex;align-items:center;gap:4px;background:rgba(59,130,246,.15);border:1px solid rgba(59,130,246,.25);border-radius:20px;padding:3px 9px;font-size:.65rem;color:#93c5fd;margin:2px}
#SR-info{display:flex;flex-direction:column;gap:10px}
.sr-seller{display:flex;align-items:center;gap:10px}
.sr-avatar{width:36px;height:36px;border-radius:50%;background:linear-gradient(135deg,#3b82f6,#6366f1);display:flex;align-items:center;justify-content:center;font-family:'Syne',sans-serif;font-weight:800;font-size:.9rem;color:#fff;flex-shrink:0}
.sr-seller-info{display:flex;flex-direction:column;gap:2px}
.sr-seller-name{font-weight:600;font-size:.85rem}
.sr-seller-sub{font-size:.7rem;color:rgba(255,255,255,.4)}
.sr-buy-btn{background:#fff;color:#000;border:none;border-radius:10px;padding:11px 16px;font-family:'Syne',sans-serif;font-weight:700;font-size:.82rem;cursor:pointer;text-decoration:none;text-align:center;display:block;transition:opacity .15s}
.sr-buy-btn:hover{opacity:.88}
#SR-empty{display:flex;flex-direction:column;align-items:center;justify-content:center;height:100%;gap:8px;color:rgba(255,255,255,.2);font-size:.8rem;text-align:center}

/* Mobile: hide sidebars, feed goes full width */
@media(max-width:700px){
  #SL,#SR{display:none}
  #FC{width:100%;max-width:none;min-width:0}
  #H{display:flex}
  #MB{right:16px}
}
/* On desktop hide the old top header */
@media(min-width:701px){
  #H{display:none}
  #MB{right:calc(50% - calc(100dvh * 9/32) - 56px)} /* position mute btn just outside feed */
}

#H{position:fixed;top:0;left:0;right:0;z-index:100;display:flex;align-items:center;justify-content:space-between;padding:14px 20px;background:linear-gradient(to bottom,rgba(0,0,0,.85),transparent)}
#H .logo{display:flex;align-items:center;gap:8px;font-family:'Syne',sans-serif;font-weight:800;font-size:1.3rem;letter-spacing:-.02em;color:#fff;text-decoration:none}
#H .logo svg{width:22px;height:22px}
.bx{background:linear-gradient(135deg,#3b82f6,#6366f1);color:#fff;font-family:'Syne',sans-serif;font-weight:700;font-size:.75rem;letter-spacing:.08em;padding:4px 10px;border-radius:20px}

#F{height:100dvh;overflow-y:scroll;scroll-snap-type:y mandatory;scroll-behavior:smooth;-webkit-overflow-scrolling:touch}
#F::-webkit-scrollbar{display:none}
.s{height:100dvh;width:100%;scroll-snap-align:start;position:relative;display:flex;align-items:flex-end;background:#0a0a0a;overflow:hidden;cursor:pointer}
.v{position:absolute;inset:0;width:100%;height:100%;object-fit:cover}
.o{position:absolute;inset:0;background:linear-gradient(to top,rgba(0,0,0,.82),rgba(0,0,0,.3) 40%,rgba(0,0,0,.1) 70%,transparent)}
.c{position:relative;z-index:10;padding:0 16px 32px;width:calc(100% - 72px)}
.cat{display:inline-flex;align-items:center;gap:5px;background:rgba(59,130,246,.25);border:1px solid rgba(59,130,246,.4);border-radius:20px;padding:3px 10px;font-size:.7rem;font-weight:500;color:#93c5fd;letter-spacing:.04em;margin-bottom:8px;backdrop-filter:blur(6px)}
.tt{font-family:'Syne',sans-serif;font-size:1.25rem;font-weight:700;line-height:1.2;margin-bottom:6px;text-shadow:0 2px 8px rgba(0,0,0,.5)}
.sl{font-size:.82rem;color:rgba(255,255,255,.65);margin-bottom:10px}
.sl span{color:rgba(255,255,255,.9);font-weight:500}
.pr{font-family:'Syne',sans-serif;font-size:1.5rem;font-weight:800;color:#fff;margin-bottom:14px}
.ar{display:flex;gap:10px}
.bvl{flex:1;background:#fff;color:#000;border:none;border-radius:12px;padding:12px 16px;font-family:'Syne',sans-serif;font-weight:700;font-size:.88rem;cursor:pointer;text-align:center;text-decoration:none;display:flex;align-items:center;justify-content:center;gap:6px;transition:background .15s,transform .1s}
.bvl:active{transform:scale(.97)}
.bsv{background:rgba(255,255,255,.12);border:1px solid rgba(255,255,255,.18);border-radius:12px;padding:12px 14px;color:#fff;cursor:pointer;backdrop-filter:blur(8px);transition:background .15s;display:flex;align-items:center}
.bsv:hover{background:rgba(255,255,255,.2)}
.sb{position:absolute;right:14px;bottom:100px;z-index:10;display:flex;flex-direction:column;gap:20px;align-items:center}
.sbb{display:flex;flex-direction:column;align-items:center;gap:4px;cursor:pointer;background:none;border:none;color:#fff}
.sbi{width:44px;height:44px;background:rgba(255,255,255,.15);border-radius:50%;display:flex;align-items:center;justify-content:center;backdrop-filter:blur(8px);transition:background .15s,transform .1s}
.sbb:active .sbi{transform:scale(.9)}
.sbi:hover{background:rgba(255,255,255,.25)}
.sbb span{font-size:.65rem;color:rgba(255,255,255,.75)}
.tb{position:absolute;bottom:0;left:0;height:3px;background:linear-gradient(to right,#3b82f6,#6366f1);width:0%;transition:width linear}
.tb.p{opacity:.45}
#MB{position:fixed;top:70px;right:16px;z-index:200;background:rgba(0,0,0,.5);border:1px solid rgba(255,255,255,.15);border-radius:50%;width:38px;height:38px;display:flex;align-items:center;justify-content:center;cursor:pointer;backdrop-filter:blur(8px);color:#fff}
.pi{position:absolute;inset:0;z-index:20;display:flex;align-items:center;justify-content:center;pointer-events:none;opacity:0;transition:opacity .15s}
.pi svg{filter:drop-shadow(0 2px 12px rgba(0,0,0,.6))}
.s.paused .pi{opacity:1}
.ve{position:absolute;inset:0;z-index:15;display:none;flex-direction:column;align-items:center;justify-content:center;gap:10px;color:rgba(255,255,255,.5);font-size:.85rem}
.s.vf .ve{display:flex}
.s.vf .v{opacity:0}
.hb{position:absolute;z-index:30;pointer-events:none;font-size:56px;line-height:1;transform:scale(0);animation:hP .6s ease-out forwards}
@keyframes hP{0%{transform:scale(0);opacity:1}40%{transform:scale(1.3);opacity:1}70%{transform:scale(1);opacity:1}100%{transform:scale(1.1);opacity:0}}
.ef{height:100dvh;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:16px;color:rgba(255,255,255,.5);text-align:center;padding:40px}
.ef h2{font-family:'Syne',sans-serif;font-size:1.4rem;color:#fff}
.ef p{font-size:.9rem;max-width:280px;line-height:1.6}
.ei{width:64px;height:64px;background:rgba(59,130,246,.15);border-radius:50%;display:flex;align-items:center;justify-content:margin-bottom:8px}
.sh{position:absolute;bottom:48px;right:50%;transform:translateX(50%);display:flex;flex-direction:column;align-items:center;gap:4px;animation:bn 1.5s ease-in-out infinite;font-size:.65rem;color:#fff;transition:opacity .4s;opacity:.5}
.sh.h{opacity:0;pointer-events:none}
@keyframes bn{0%,100%{transform:translateX(50%) translateY(0)}50%{transform:translateX(50%) translateY(-6px)}}
.liked .sbi{background:rgba(239,68,68,.4)!important}
.saved .sbi{background:rgba(99,102,241,.4)!important}
/* Mute button — positioned inside feed on mobile, just above feed on desktop */
#MB{position:fixed;top:16px;right:16px;z-index:200;background:rgba(0,0,0,.5);border:1px solid rgba(255,255,255,.15);border-radius:50%;width:38px;height:38px;display:flex;align-items:center;justify-content:center;cursor:pointer;backdrop-filter:blur(8px);color:#fff}
@media(min-width:701px){
  #MB{right:auto;left:calc(50% + min(calc(100dvh * 9/32), 240px) + 12px);top:16px}
}
#auth-toast{position:fixed;bottom:80px;left:50%;transform:translateX(-50%) translateY(20px);background:rgba(20,20,20,.95);border:1px solid rgba(255,255,255,.15);border-radius:12px;padding:10px 18px;font-size:.82rem;color:#fff;z-index:300;opacity:0;transition:opacity .2s,transform .2s;pointer-events:none;white-space:nowrap}
#auth-toast.show{opacity:1;transform:translateX(-50%) translateY(0)}
#auth-toast a{color:#3b82f6;text-decoration:none;font-weight:600}
</style>

<!-- Mobile header -->
<div id="H">
  <a href="/" class="logo"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>Nox</a>
  <span class="bx">⚡ CLICKZ</span>
  <a href="/products" style="color:rgba(255,255,255,.6);font-size:.8rem;text-decoration:none;">Browse →</a>
</div>

<button id="MB" title="Toggle mute"><svg id="MI" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/><path d="M15.54 8.46a5 5 0 0 1 0 7.07"/><path d="M19.07 4.93a10 10 0 0 1 0 14.14"/></svg></button>

<div id="auth-toast"><a href="/login">Sign in</a> to like items</div>

<div id="shell">

  <!-- Left sidebar (desktop only) -->
  <div id="SL">
    <a href="/" class="logo">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
      Nox
    </a>
    <nav class="snav">
      <a href="/clickz" class="active">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="23 7 16 12 23 17 23 7"/><rect x="1" y="5" width="15" height="14" rx="2"/></svg>
        Clickz
      </a>
      <a href="/products">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
        Browse
      </a>
      <a href="/sell">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
        Sell
      </a>
      <a href="/profile">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
        Profile
      </a>
    </nav>
    <div class="sl-bottom">
      <a href="/sell/clickz" class="sl-post">+ Post Clickz</a>
    </div>
  </div>

  <!-- Center feed column -->
  <div id="FC">
    <div id="F">
{C.length===0?(
  <div class="s"><div class="ef"><div class="ei"><svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#3b82f6" stroke-width="2"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg></div><h2>No Clickz yet</h2><p>Be the first seller to post an 8-second product Clickz and reach thousands of builders.</p><a href="/sell/clickz" style="margin-top:8px;background:linear-gradient(135deg,#3b82f6,#6366f1);color:#fff;padding:12px 24px;border-radius:12px;font-family:'Syne',sans-serif;font-weight:700;text-decoration:none;font-size:.9rem;">Post a Clickz →</a></div></div>
):(
  C.map((item:Clickz,i:number)=>(
    <div class="s" data-index={i} data-id={item.id} data-price={item.metadata?.price||'0'} data-category={item.metadata?.category||''} data-ts={(item as any).created_at||''} data-likes={item.metadata?.likes||0} data-views={(item.metadata as any)?.views||0} data-seller-score={(item.metadata as any)?.seller_score||50}>
      <!-- FIX 3: autoplay — muted required by browser policy, preload metadata for next slides -->
      <video class="v" src={item.metadata?.video?.url||''} playsinline loop muted preload={i===0?'auto':i===1?'metadata':'none'} poster={item.metadata?.thumbnail?.imgix_url?`${item.metadata.thumbnail.imgix_url}?w=40&blur=20&auto=format`:''} />
      <div class="o"/><div class="tb"/>
      <div class="pi"><svg width="64" height="64" viewBox="0 0 24 24" fill="rgba(255,255,255,.85)" stroke="none"><rect x="6" y="4" width="4" height="16" rx="1"/><rect x="14" y="4" width="4" height="16" rx="1"/></svg></div>
      <div class="ve"><svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>Video unavailable</div>
      <div class="sb">
        <button class="sbb like-btn" data-id={item.id}><div class="sbi"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg></div><span class="lc">{item.metadata?.likes||0}</span></button>
        <button class="sbb share-btn" data-id={item.id} data-slug={item.slug}><div class="sbi"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/></svg></div><span>Share</span></button>
        <a href={`/products/${item.slug}`} class="sbb buy-btn" data-id={item.id}><div class="sbi"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg></div><span>Buy</span></a>
      </div>
      <div class="c">
        <div class="cat">⚡ {item.metadata?.category||'PC Part'}</div>
        <div class="tt">{item.title}</div>
        <div class="sl">by <span>{item.metadata?.seller_name||'Seller'}</span></div>
        <div class="pr">${item.metadata?.price||'—'}</div>
        <div class="ar">
          <a href={`/products/${item.slug}`} class="bvl buy-btn" data-id={item.id}><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>View Full Listing</a>
          <button class="bsv save-btn" data-id={item.id}><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"/></svg></button>
        </div>
      </div>
      {i===0&&<div class="sh" id="SH"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>Scroll</div>}
    </div>
  ))
)}
</div><!-- end #F -->
  </div><!-- end #FC -->

  <!-- Right sidebar (desktop only) -->
  <div id="SR">
    <div class="sr-title">Now Playing</div>
    <div id="SR-info">
      <div id="SR-empty">
        <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polygon points="23 7 16 12 23 17 23 7"/><rect x="1" y="5" width="15" height="14" rx="2"/></svg>
        Scroll to a listing
      </div>
    </div>
  </div>

</div><!-- end #shell -->
</Layout>

<script>
  import { NoxTracker } from '@/lib/nox-tracker.js';

  declare global {
    interface Window {
      CookieConsent?: { consent?: { statistics?: boolean } };
    }
  }

  function tryInit() {
    if (window.CookieConsent?.consent?.statistics) NoxTracker.init();
  }

  tryInit();

  window.addEventListener('CookiebotOnAccept', () => {
    if (window.CookieConsent?.consent?.statistics) NoxTracker.init();
  });

  window.addEventListener('CookiebotOnLoad', tryInit);
</script>

<script is:inline>
const F=document.getElementById('F'),MB=document.getElementById('MB'),MI=document.getElementById('MI'),SH=document.getElementById('SH');
const authToast=document.getElementById('auth-toast');
const MS=`<polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/><line x1="23" y1="9" x2="17" y2="15"/><line x1="17" y1="9" x2="23" y2="15"/>`;
const US=`<polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/><path d="M15.54 8.46a5 5 0 0 1 0 7.07"/><path d="M19.07 4.93a10 10 0 0 1 0 14.14"/>`;

// FIX 1 & 2: Auth state + like rate limiting
// isAuthed: checks for a nox_session cookie (adjust cookie name to match your auth setup)
const isAuthed=()=>document.cookie.split(';').some(c=>c.trim().startsWith('noxmarket_authed=1'));

// Like cooldown: keyed by item id in localStorage, 500ms debounce window
const LIKE_COOLDOWN=500;
const getLikeTs=(id)=>{try{return parseInt(localStorage.getItem('nox_like_ts_'+id)||'0')}catch{return 0}};
const setLikeTs=(id)=>{try{localStorage.setItem('nox_like_ts_'+id,String(Date.now()))}catch{}};
const canLike=(id)=>Date.now()-getLikeTs(id)>LIKE_COOLDOWN;

// Per-session liked set (survives re-renders, not localStorage so clears on tab close — prevents like-spam across refreshes too)
// For persistence across sessions, swap sessionStorage for localStorage
const likedThisSession=new Set(JSON.parse(sessionStorage.getItem('nox_liked')||'[]'));
const saveLiked=()=>{try{sessionStorage.setItem('nox_liked',JSON.stringify([...likedThisSession]))}catch{}};

let toastTimer=null;
function showAuthToast(){
  if(toastTimer)clearTimeout(toastTimer);
  authToast.classList.add('show');
  toastTimer=setTimeout(()=>authToast.classList.remove('show'),2500);
}

// Right sidebar updater
function updateSidebar(s){
  const sr=document.getElementById('SR-info');
  if(!sr||window.innerWidth<=700)return;
  const title=s.querySelector('.tt')?.textContent||'';
  const price=s.querySelector('.pr')?.textContent||'';
  const seller=s.querySelector('.sl span')?.textContent||'Seller';
  const cat=s.querySelector('.cat')?.textContent?.replace('⚡ ','')||'';
  const likes=s.querySelector('.lc')?.textContent||'0';
  const slug=s.querySelector('a.buy-btn')?.getAttribute('href')||'#';
  const initial=seller.trim()[0]?.toUpperCase()||'S';
  sr.innerHTML=`
    <div class="sr-seller">
      <div class="sr-avatar">${initial}</div>
      <div class="sr-seller-info">
        <div class="sr-seller-name">${seller}</div>
        <div class="sr-seller-sub">Verified Seller</div>
      </div>
    </div>
    <div class="sr-divider"></div>
    <div class="sr-card">
      <div class="sr-card-label">Listing</div>
      <div class="sr-card-value" style="font-size:.95rem;line-height:1.3">${title}</div>
    </div>
    <div class="sr-card">
      <div class="sr-card-label">Price</div>
      <div class="sr-card-value">${price}</div>
    </div>
    <div style="display:flex;gap:8px;flex-wrap:wrap">
      <span class="sr-tag">⚡ ${cat}</span>
      <span class="sr-tag">♥ ${likes} likes</span>
    </div>
    <div class="sr-divider"></div>
    <a href="${slug}" class="sr-buy-btn">View Full Listing →</a>
  `;
}

let muted=true,cv=null,cs=null,ti=null,paused=false,te=0; // FIX 3: muted=true by default for autoplay
const N=()=>window.__nox;
const bar=s=>s.querySelector('.tb');
const startT=s=>{bar(s).classList.remove('p');ti=setInterval(()=>{te+=100;const b=bar(s);b.style.transition='width 0.1s linear';b.style.width=Math.min(te/80,100)+'%';if(te>=8000){clearInterval(ti);N()?.rerank();s.nextElementSibling?.scrollIntoView({behavior:'smooth'})}},100)};
const stopT=s=>{if(ti){clearInterval(ti);ti=null}bar(s).classList.add('p')};
const tog=s=>{const v=s.querySelector('video');if(!v)return;if(paused){v.play().catch(()=>{});s.classList.remove('paused');paused=false;startT(s)}else{v.pause();s.classList.add('paused');paused=true;stopT(s)}};
const heart=(s,x,y)=>{const h=document.createElement('div');h.className='hb';h.textContent='❤️';const r=s.getBoundingClientRect();h.style.cssText=`left:${x-r.left-28}px;top:${y-r.top-28}px`;s.appendChild(h);h.addEventListener('animationend',()=>h.remove())};
const pa=s=>{[s.nextElementSibling,s.nextElementSibling?.nextElementSibling].forEach((n,i)=>{if(!n)return;const v=n.querySelector('video');if(v&&v.preload!=='auto')v.preload=i===0?'auto':'metadata'})};

// FIX 3: play() now always sets muted=true before calling v.play() so autoplay works
function play(s){
  const v=s.querySelector('video'),b=bar(s);
  paused=false;te=0;cs=s;
  if(cv&&cv!==v){cv.pause();cv.currentTime=0;cv.closest('.s')?.classList.remove('paused')}
  if(ti)clearInterval(ti);
  b.style.transition='none';b.style.width='0%';b.classList.remove('p');
  if(v){
    v.muted=muted; // respect current mute state
    v.currentTime=0;cv=v;
    v.onerror=()=>{s.classList.add('vf');if(ti)clearInterval(ti)};
    // Always attempt autoplay; browsers allow muted autoplay
    const playPromise=v.play();
    if(playPromise!==undefined){
      playPromise.catch(()=>{
        // Autoplay blocked (shouldn't happen when muted, but just in case)
        s.classList.add('paused');paused=true;
      });
    }
    startT(s);pa(s);updateSidebar(s);
  }
}

async function patchLikes(id,n){
  try{
    await fetch(`/api/clickz/${id}/likes`,{
      method:'PATCH',
      headers:{'Content-Type':'application/json'},
      credentials:'include',
      body:JSON.stringify({likes:n})
    });
  }catch{}
}

// FIX 1 & 2: hLike now checks auth and rate limits before toggling
function hLike(e){
  e.stopPropagation();
  const btn=e.currentTarget.closest('.like-btn');
  if(!btn)return;
  const id=btn.dataset.id;

  // Auth check
  if(!isAuthed()){showAuthToast();return;}

  // Rate limit: prevent spam clicking
  if(!canLike(id))return;
  setLikeTs(id);

  const ic=btn.querySelector('.sbi'),ct=btn.querySelector('.lc');
  const alreadyLiked=likedThisSession.has(id);

  if(alreadyLiked){
    // Unlike
    likedThisSession.delete(id);
    saveLiked();
    btn.classList.remove('liked');
    const n=Math.max(0,parseInt(ct.textContent||'0')-1);
    ct.textContent=String(n);
    patchLikes(id,n);
  } else {
    // Like
    likedThisSession.add(id);
    saveLiked();
    btn.classList.add('liked');
    const n=parseInt(ct.textContent||'0')+1;
    ct.textContent=String(n);
    N()?.onLike(id);
    patchLikes(id,n);
    ic.animate([{transform:'scale(1)'},{transform:'scale(1.35)'},{transform:'scale(1)'}],{duration:250,easing:'ease-out'});
  }
}

// Also restore liked state visually on page load
function restoreLikedState(s){
  const id=s.dataset.id;
  const btn=s.querySelector('.like-btn');
  if(btn&&likedThisSession.has(id))btn.classList.add('liked');
}

function hSave(e){e.stopPropagation();const b=e.currentTarget;N()?.onSave(b.dataset.id);b.classList.add('saved')}
function hBuy(e){e.stopPropagation();N()?.onBuy(e.currentTarget.dataset.id)}
function hShare(e){e.stopPropagation();const b=e.currentTarget,id=b.dataset.id,sl=b.dataset.slug;N()?.onShare(id);const u=`${location.origin}/products/${sl}`;navigator.share?navigator.share({title:'Check this out on Nox',url:u}):navigator.clipboard.writeText(u).then(()=>alert('Link copied!'))}
const tt=new WeakMap();

// FIX 2: double-tap to like also checks auth and rate limit
function hTap(e){
  const s=e.currentTarget;
  if(e.target.closest('a,button'))return;
  if(tt.has(s)){
    clearTimeout(tt.get(s));tt.delete(s);
    const lb=s.querySelector('.like-btn');
    const id=s.dataset.id;
    if(lb&&!likedThisSession.has(id)){
      if(!isAuthed()){showAuthToast();return;}
      if(!canLike(id))return;
      setLikeTs(id);
      likedThisSession.add(id);saveLiked();
      lb.classList.add('liked');
      const c=lb.querySelector('.lc');
      const n=parseInt(c.textContent||'0')+1;
      c.textContent=String(n);
      N()?.onLike(id);
      patchLikes(id,n);
      lb.querySelector('.sbi').animate([{transform:'scale(1)'},{transform:'scale(1.35)'},{transform:'scale(1)'}],{duration:250,easing:'ease-out'});
    }
    heart(s,e.clientX,e.clientY);
  }else{
    const t=setTimeout(()=>{tt.delete(s);tog(s)},220);
    tt.set(s,t);
  }
}

// FIX 3: threshold lowered to 0.6 so video starts slightly earlier while scrolling
const obs=new IntersectionObserver(es=>es.forEach(e=>{if(e.isIntersecting)play(e.target)}),{threshold:.6});
const reg=new WeakSet();
function regSlide(s){
  if(reg.has(s))return;
  reg.add(s);
  obs.observe(s);
  restoreLikedState(s);
  s.addEventListener('click',hTap);
  s.querySelector('.like-btn')?.addEventListener('click',hLike);
  s.querySelector('.save-btn')?.addEventListener('click',hSave);
  s.querySelectorAll('.buy-btn').forEach(b=>b.addEventListener('click',hBuy));
  s.querySelector('.share-btn')?.addEventListener('click',hShare);
}

document.querySelectorAll('.s').forEach(regSlide);
new MutationObserver(ms=>ms.forEach(m=>m.addedNodes.forEach(n=>{if(!(n instanceof HTMLElement))return;if(n.classList.contains('s'))regSlide(n);n.querySelectorAll('.s').forEach(regSlide)}))).observe(F,{childList:true,subtree:true});

// FIX 3: mute button now toggles properly and updates icon; starts muted
MB.addEventListener('click',()=>{
  muted=!muted;
  if(cv)cv.muted=muted;
  MI.innerHTML=muted?MS:US;
});
// Set initial icon to unmuted state (showing sound icon, user can mute)
// Video starts muted for autoplay, but icon shows "sound on" so user knows they can hear it
MI.innerHTML=US;

if(SH){const h=()=>SH.classList.add('h');setTimeout(h,3000);F.addEventListener('scroll',h,{once:true});}
let ty=0,tm=0;
F.addEventListener('touchstart',e=>{if(e.touches[0]){ty=e.touches[0].clientY;tm=Date.now()}},{passive:true});
F.addEventListener('touchend',e=>{if(!e.changedTouches[0])return;const dy=ty-e.changedTouches[0].clientY,dt=Date.now()-tm;if(Math.abs(dy)/dt>.5&&Math.abs(dy)>40){const ss=Array.from(F.querySelectorAll('.s')),cur=ss.find(s=>{const r=s.getBoundingClientRect();return r.top>=-10&&r.top<=10});if(cur){const tg=dy>0?cur.nextElementSibling:cur.previousElementSibling;tg?.scrollIntoView({behavior:'smooth'})}}},{passive:true});
document.addEventListener('keydown',e=>{if(!cs)return;if(e.key==='ArrowDown'||e.key==='ArrowRight'){e.preventDefault();cs.nextElementSibling?.scrollIntoView({behavior:'smooth'})}else if(e.key==='ArrowUp'||e.key==='ArrowLeft'){e.preventDefault();cs.previousElementSibling?.scrollIntoView({behavior:'smooth'})}else if(e.key===' '){e.preventDefault();tog(cs)}});
</script>
