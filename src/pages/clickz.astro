---
import Layout from '@/layouts/Layout.astro';
import { getClickz } from '@/lib/cosmic';
import type { Clickz } from '@/types';

const clickzItems = await getClickz();
---

<Layout title="Clickz — Nox">
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:wght@300;400;500&display=swap');
    *{box-sizing:border-box;margin:0;padding:0}
    body{background:#000;color:#fff;font-family:'DM Sans',sans-serif;overflow:hidden}
    #clickz-header{position:fixed;top:0;left:0;right:0;z-index:100;display:flex;align-items:center;justify-content:space-between;padding:14px 20px;background:linear-gradient(to bottom,rgba(0,0,0,.85) 0%,transparent 100%)}
    #clickz-header .logo{display:flex;align-items:center;gap:8px;font-family:'Syne',sans-serif;font-weight:800;font-size:1.3rem;letter-spacing:-.02em;color:#fff;text-decoration:none}
    #clickz-header .logo svg{width:22px;height:22px}
    .clickz-badge{background:linear-gradient(135deg,#3b82f6,#6366f1);color:#fff;font-family:'Syne',sans-serif;font-weight:700;font-size:.75rem;letter-spacing:.08em;padding:4px 10px;border-radius:20px}
    #feed-container{height:100dvh;overflow-y:scroll;scroll-snap-type:y mandatory;scroll-behavior:smooth;-webkit-overflow-scrolling:touch}
    #feed-container::-webkit-scrollbar{display:none}
    .clickz-slide{height:100dvh;width:100%;scroll-snap-align:start;position:relative;display:flex;align-items:flex-end;background:#0a0a0a;overflow:hidden}
    .clickz-video{position:absolute;inset:0;width:100%;height:100%;object-fit:cover}
    .clickz-overlay{position:absolute;inset:0;background:linear-gradient(to top,rgba(0,0,0,.82) 0%,rgba(0,0,0,.3) 40%,rgba(0,0,0,.1) 70%,transparent 100%)}
    .clickz-content{position:relative;z-index:10;padding:0 16px 32px 16px;width:calc(100% - 72px)}
    .part-category{display:inline-flex;align-items:center;gap:5px;background:rgba(59,130,246,.25);border:1px solid rgba(59,130,246,.4);border-radius:20px;padding:3px 10px;font-size:.7rem;font-weight:500;color:#93c5fd;letter-spacing:.04em;margin-bottom:8px;backdrop-filter:blur(6px)}
    .clickz-title{font-family:'Syne',sans-serif;font-size:1.25rem;font-weight:700;line-height:1.2;margin-bottom:6px;text-shadow:0 2px 8px rgba(0,0,0,.5)}
    .clickz-seller{font-size:.82rem;color:rgba(255,255,255,.65);margin-bottom:10px}
    .clickz-seller span{color:rgba(255,255,255,.9);font-weight:500}
    .clickz-price{font-family:'Syne',sans-serif;font-size:1.5rem;font-weight:800;color:#fff;margin-bottom:14px}
    .clickz-actions-row{display:flex;gap:10px}
    .btn-view-listing{flex:1;background:#fff;color:#000;border:none;border-radius:12px;padding:12px 16px;font-family:'Syne',sans-serif;font-weight:700;font-size:.88rem;cursor:pointer;text-align:center;text-decoration:none;display:flex;align-items:center;justify-content:center;gap:6px;transition:background .15s,transform .1s}
    .btn-view-listing:active{transform:scale(.97)}
    .btn-save{background:rgba(255,255,255,.12);border:1px solid rgba(255,255,255,.18);border-radius:12px;padding:12px 14px;color:#fff;cursor:pointer;backdrop-filter:blur(8px);transition:background .15s;display:flex;align-items:center}
    .btn-save:hover{background:rgba(255,255,255,.2)}
    .clickz-sidebar{position:absolute;right:14px;bottom:100px;z-index:10;display:flex;flex-direction:column;gap:20px;align-items:center}
    .sidebar-btn{display:flex;flex-direction:column;align-items:center;gap:4px;cursor:pointer;background:none;border:none;color:#fff}
    .sidebar-btn-icon{width:44px;height:44px;background:rgba(255,255,255,.15);border-radius:50%;display:flex;align-items:center;justify-content:center;backdrop-filter:blur(8px);transition:background .15s,transform .1s}
    .sidebar-btn:active .sidebar-btn-icon{transform:scale(.9)}
    .sidebar-btn-icon:hover{background:rgba(255,255,255,.25)}
    .sidebar-btn span{font-size:.65rem;color:rgba(255,255,255,.75)}
    .timer-bar{position:absolute;bottom:0;left:0;height:3px;background:linear-gradient(to right,#3b82f6,#6366f1);width:0%;transition:width linear}
    #mute-btn{position:fixed;top:70px;right:16px;z-index:200;background:rgba(0,0,0,.5);border:1px solid rgba(255,255,255,.15);border-radius:50%;width:38px;height:38px;display:flex;align-items:center;justify-content:center;cursor:pointer;backdrop-filter:blur(8px);color:#fff}
    .empty-feed{height:100dvh;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:16px;color:rgba(255,255,255,.5);text-align:center;padding:40px}
    .empty-feed h2{font-family:'Syne',sans-serif;font-size:1.4rem;color:#fff}
    .empty-feed p{font-size:.9rem;max-width:280px;line-height:1.6}
    .empty-icon{width:64px;height:64px;background:rgba(59,130,246,.15);border-radius:50%;display:flex;align-items:center;justify-content:center;margin-bottom:8px}
    .scroll-hint{position:absolute;bottom:48px;right:50%;transform:translateX(50%);display:flex;flex-direction:column;align-items:center;gap:4px;animation:bounce 1.5s ease-in-out infinite;opacity:.5;font-size:.65rem;color:#fff}
    @keyframes bounce{0%,100%{transform:translateX(50%) translateY(0)}50%{transform:translateX(50%) translateY(-6px)}}
    .liked .sidebar-btn-icon{background:rgba(239,68,68,.4)!important}
    .saved .sidebar-btn-icon{background:rgba(99,102,241,.4)!important}
  </style>

  <div id="clickz-header">
    <a href="/" class="logo">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
      Nox
    </a>
    <span class="clickz-badge">⚡ CLICKZ</span>
    <a href="/products" style="color:rgba(255,255,255,.6);font-size:.8rem;text-decoration:none;">Browse →</a>
  </div>

  <button id="mute-btn" title="Toggle mute">
    <svg id="mute-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/>
      <line x1="23" y1="9" x2="17" y2="15"/><line x1="17" y1="9" x2="23" y2="15"/>
    </svg>
  </button>

  <div id="feed-container">
    {clickzItems.length === 0 ? (
      <div class="clickz-slide">
        <div class="empty-feed">
          <div class="empty-icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#3b82f6" stroke-width="2"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
          </div>
          <h2>No Clickz yet</h2>
          <p>Be the first seller to post an 8-second product Clickz and reach thousands of builders.</p>
          <a href="/sell/clickz" style="margin-top:8px;background:linear-gradient(135deg,#3b82f6,#6366f1);color:#fff;padding:12px 24px;border-radius:12px;font-family:'Syne',sans-serif;font-weight:700;text-decoration:none;font-size:.9rem;">Post a Clickz →</a>
        </div>
      </div>
    ) : (
      clickzItems.map((item: Clickz, i: number) => (
        <div class="clickz-slide" data-index={i} data-id={item.id}
             data-price={item.metadata?.price || '0'}
             data-category={item.metadata?.category || ''}>
          <video class="clickz-video" src={item.metadata?.video?.url || ''} playsinline loop muted
            preload={i === 0 ? 'auto' : 'none'} poster={item.metadata?.thumbnail?.imgix_url || ''} />
          <div class="clickz-overlay" />
          <div class="timer-bar" />
          <div class="clickz-sidebar">
            <button class="sidebar-btn like-btn" data-id={item.id}>
              <div class="sidebar-btn-icon">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
                </svg>
              </div>
              <span class="like-count">{item.metadata?.likes || 0}</span>
            </button>
            <button class="sidebar-btn share-btn" data-id={item.id} data-slug={item.slug}>
              <div class="sidebar-btn-icon">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/>
                  <line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/>
                </svg>
              </div>
              <span>Share</span>
            </button>
            <a href={`/products/${item.slug}`} class="sidebar-btn buy-btn" data-id={item.id}>
              <div class="sidebar-btn-icon">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/>
                  <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/>
                </svg>
              </div>
              <span>Buy</span>
            </a>
          </div>
          <div class="clickz-content">
            <div class="part-category">⚡ {item.metadata?.category || 'PC Part'}</div>
            <div class="clickz-title">{item.title}</div>
            <div class="clickz-seller">by <span>{item.metadata?.seller_name || 'Seller'}</span></div>
            <div class="clickz-price">${item.metadata?.price || '—'}</div>
            <div class="clickz-actions-row">
              <a href={`/products/${item.slug}`} class="btn-view-listing buy-btn" data-id={item.id}>
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                  <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/>
                </svg>
                View Full Listing
              </a>
              <button class="btn-save save-btn" data-id={item.id}>
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"/>
                </svg>
              </button>
            </div>
          </div>
          {i === 0 && (
            <div class="scroll-hint">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
              Scroll
            </div>
          )}
        </div>
      ))
    )}
  </div>
</Layout>

<script>
  // ── ML Engine ──────────────────────────────────────────────────────────────
  // 8-dim user vector: [budget, category, pace, rewatch, buyIntent, share, depth, recency]
  const CATS = ['gpu','cpu','ram','ssd','case','psu','cooler','mobo','monitor','peripheral'];
  const clamp = (v: number) => Math.max(0, Math.min(1, v));
  const catHash = (c: string) => { const i = CATS.findIndex(x => c.toLowerCase().includes(x)); return i === -1 ? 0.5 : (i+1)/CATS.length; };
  const dot = (a: number[], b: number[]) => a.reduce((s,v,i) => s + v*b[i], 0);
  const mag = (a: number[]) => Math.sqrt(a.reduce((s,v) => s+v*v, 0));
  const cosine = (a: number[], b: number[]) => { const m = mag(a)*mag(b); return m ? dot(a,b)/m : 0; };

  let uv: number[] = JSON.parse(localStorage.getItem('nox_uv') || 'null') || new Array(8).fill(0.5);
  let ic: number = parseInt(localStorage.getItem('nox_ic') || '0');
  let lr = Math.max(0.01, 0.08 / Math.sqrt(1 + ic * 0.1));
  const cvMap: Record<string, number[]> = {};

  const saveUV = () => { localStorage.setItem('nox_uv', JSON.stringify(uv)); localStorage.setItem('nox_ic', String(ic)); };

  const nudge = (id: string, signal: number) => {
    const cv = cvMap[id]; if (!cv) return;
    const err = signal - cosine(uv, cv);
    uv = uv.map((v,i) => clamp(v + lr * err * cv[i]));
    ic++; lr = Math.max(0.01, 0.08 / Math.sqrt(1 + ic * 0.1));
    saveUV();
  };

  // Decay old behavior toward neutral on each session load
  uv = uv.map(v => clamp(v + (0.5 - v) * 0.005));

  // Register slides
  document.querySelectorAll<HTMLElement>('.clickz-slide').forEach(s => {
    const id = s.dataset.id!;
    const price = clamp(parseFloat(s.dataset.price || '0') / 1000);
    const cat = catHash(s.dataset.category || '');
    cvMap[id] = [price, cat, 0.5, 0.5, 0.5, 0.5, 0.5, 1.0];
  });

  const score = (id: string) => cosine(uv, cvMap[id] || new Array(8).fill(0.5));

  const rerankFeed = (feed: HTMLElement) => {
    const slides = Array.from(feed.querySelectorAll<HTMLElement>('.clickz-slide'));
    const active = slides.find(s => { const r = s.getBoundingClientRect(); return r.top >= 0 && r.top < window.innerHeight; });
    const pivot = active ? slides.indexOf(active) + 1 : 0;
    slides.slice(pivot)
      .sort((a, b) => score(b.dataset.id!) - score(a.dataset.id!))
      .forEach(s => feed.appendChild(s));
  };

  // ── Feed Logic ─────────────────────────────────────────────────────────────
  const feed = document.getElementById('feed-container')!;
  const muteBtn = document.getElementById('mute-btn')!;
  const muteIcon = document.getElementById('mute-icon')!;
  let isMuted = true, currentVideo: HTMLVideoElement | null = null;
  let currentId: string | null = null, lastId: string | null = null;
  let timerInterval: ReturnType<typeof setInterval> | null = null;
  let watchStart: number | null = null;

  const MUTE_SVG = `<polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/><line x1="23" y1="9" x2="17" y2="15"/><line x1="17" y1="9" x2="23" y2="15"/>`;
  const UNMUTE_SVG = `<polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/><path d="M15.54 8.46a5 5 0 0 1 0 7.07"/><path d="M19.07 4.93a10 10 0 0 1 0 14.14"/>`;

  function playSlide(slide: Element) {
    const video = slide.querySelector('video') as HTMLVideoElement;
    const bar = slide.querySelector('.timer-bar') as HTMLElement;
    const id = (slide as HTMLElement).dataset.id!;

    // Log watch % for outgoing slide
    if (currentId && watchStart) {
      const pct = Math.min((Date.now() - watchStart) / 8000, 1);
      if (pct >= 0.8) nudge(currentId, 0.85);
      else if (pct >= 0.4) nudge(currentId, 0.6);
      else if (pct < 0.15) nudge(currentId, 0.1);
      if (currentId === lastId) nudge(currentId, 1.0); // rewatch
    }

    lastId = currentId;
    currentId = id;
    watchStart = Date.now();

    if (currentVideo && currentVideo !== video) { currentVideo.pause(); currentVideo.currentTime = 0; }
    if (timerInterval) clearInterval(timerInterval);

    if (video) {
      video.muted = isMuted;
      video.currentTime = 0;
      video.play().catch(() => {});
      currentVideo = video;

      let elapsed = 0;
      bar.style.transition = 'none';
      bar.style.width = '0%';

      timerInterval = setInterval(() => {
        elapsed += 100;
        bar.style.transition = 'width 0.1s linear';
        bar.style.width = Math.min((elapsed / 8000) * 100, 100) + '%';
        if (elapsed >= 8000) {
          clearInterval(timerInterval!);
          rerankFeed(feed);
          const next = slide.nextElementSibling;
          if (next) next.scrollIntoView({ behavior: 'smooth' });
        }
      }, 100);
    }
  }

  new IntersectionObserver(entries => {
    entries.forEach(e => { if (e.isIntersecting) playSlide(e.target); });
  }, { threshold: 0.7 }).observe(document.querySelectorAll('.clickz-slide'));

  // Mute
  muteBtn.addEventListener('click', () => {
    isMuted = !isMuted;
    if (currentVideo) currentVideo.muted = isMuted;
    muteIcon.innerHTML = isMuted ? MUTE_SVG : UNMUTE_SVG;
  });

  // Likes
  document.querySelectorAll('.like-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const id = (btn as HTMLElement).dataset.id!;
      const icon = btn.querySelector('.sidebar-btn-icon')!;
      const count = btn.querySelector('.like-count')!;
      const liked = (btn.closest('.sidebar-btn') as HTMLElement).classList.toggle('liked');
      count.textContent = String(parseInt(count.textContent||'0') + (liked ? 1 : -1));
      if (liked) nudge(id, 0.9);
      icon.animate([{transform:'scale(1)'},{transform:'scale(1.35)'},{transform:'scale(1)'}],{duration:250,easing:'ease-out'});
    });
  });

  // Saves
  document.querySelectorAll('.save-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const id = (btn as HTMLElement).dataset.id!;
      nudge(id, 0.88);
      (btn.closest('.sidebar-btn') as HTMLElement)?.classList.add('saved');
    });
  });

  // Buy clicks
  document.querySelectorAll('.buy-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const id = (btn as HTMLElement).dataset.id!;
      nudge(id, 0.95);
    });
  });

  // Shares
  document.querySelectorAll('.share-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const id = (btn as HTMLElement).dataset.id!;
      const slug = (btn as HTMLElement).dataset.slug!;
      nudge(id, 0.85);
      const url = `${location.origin}/products/${slug}`;
      navigator.share ? navigator.share({ title: 'Check this out on Nox', url }) : navigator.clipboard.writeText(url).then(() => alert('Link copied!'));
    });
  });
</script>
