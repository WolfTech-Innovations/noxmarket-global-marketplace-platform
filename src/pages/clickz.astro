---
import Layout from '@/layouts/Layout.astro';
import { getClickz } from '@/lib/cosmic';
import type { Clickz } from '@/types';
const C = await getClickz();
---
<Layout title="Clickz — Nox">
<style>
@import url('https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:wght@300;400;500&display=swap');
*{box-sizing:border-box;margin:0;padding:0}
body{background:#000;color:#fff;font-family:'DM Sans',sans-serif;overflow:hidden}
#H{position:fixed;top:0;left:0;right:0;z-index:100;display:flex;align-items:center;justify-content:space-between;padding:14px 20px;background:linear-gradient(to bottom,rgba(0,0,0,.85),transparent)}
#H .logo{display:flex;align-items:center;gap:8px;font-family:'Syne',sans-serif;font-weight:800;font-size:1.3rem;letter-spacing:-.02em;color:#fff;text-decoration:none}
#H .logo svg{width:22px;height:22px}
.bx{background:linear-gradient(135deg,#3b82f6,#6366f1);color:#fff;font-family:'Syne',sans-serif;font-weight:700;font-size:.75rem;letter-spacing:.08em;padding:4px 10px;border-radius:20px}
#F{height:100dvh;overflow-y:scroll;scroll-snap-type:y mandatory;scroll-behavior:smooth;-webkit-overflow-scrolling:touch}
#F::-webkit-scrollbar{display:none}
.s{height:100dvh;width:100%;scroll-snap-align:start;position:relative;display:flex;align-items:flex-end;background:#0a0a0a;overflow:hidden;cursor:pointer}
.v{position:absolute;inset:0;width:100%;height:100%;object-fit:cover}
.o{position:absolute;inset:0;background:linear-gradient(to top,rgba(0,0,0,.82),rgba(0,0,0,.3) 40%,rgba(0,0,0,.1) 70%,transparent)}
.c{position:relative;z-index:10;padding:0 16px 32px;width:calc(100% - 72px)}
.cat{display:inline-flex;align-items:center;gap:5px;background:rgba(59,130,246,.25);border:1px solid rgba(59,130,246,.4);border-radius:20px;padding:3px 10px;font-size:.7rem;font-weight:500;color:#93c5fd;letter-spacing:.04em;margin-bottom:8px;backdrop-filter:blur(6px)}
.tt{font-family:'Syne',sans-serif;font-size:1.25rem;font-weight:700;line-height:1.2;margin-bottom:6px;text-shadow:0 2px 8px rgba(0,0,0,.5)}
.sl{font-size:.82rem;color:rgba(255,255,255,.65);margin-bottom:10px}
.sl span{color:rgba(255,255,255,.9);font-weight:500}
.pr{font-family:'Syne',sans-serif;font-size:1.5rem;font-weight:800;color:#fff;margin-bottom:14px}
.ar{display:flex;gap:10px}
.bvl{flex:1;background:#fff;color:#000;border:none;border-radius:12px;padding:12px 16px;font-family:'Syne',sans-serif;font-weight:700;font-size:.88rem;cursor:pointer;text-align:center;text-decoration:none;display:flex;align-items:center;justify-content:center;gap:6px;transition:background .15s,transform .1s}
.bvl:active{transform:scale(.97)}
.bsv{background:rgba(255,255,255,.12);border:1px solid rgba(255,255,255,.18);border-radius:12px;padding:12px 14px;color:#fff;cursor:pointer;backdrop-filter:blur(8px);transition:background .15s;display:flex;align-items:center}
.bsv:hover{background:rgba(255,255,255,.2)}
.sb{position:absolute;right:14px;bottom:100px;z-index:10;display:flex;flex-direction:column;gap:20px;align-items:center}
.sbb{display:flex;flex-direction:column;align-items:center;gap:4px;cursor:pointer;background:none;border:none;color:#fff}
.sbi{width:44px;height:44px;background:rgba(255,255,255,.15);border-radius:50%;display:flex;align-items:center;justify-content:center;backdrop-filter:blur(8px);transition:background .15s,transform .1s}
.sbb:active .sbi{transform:scale(.9)}
.sbi:hover{background:rgba(255,255,255,.25)}
.sbb span{font-size:.65rem;color:rgba(255,255,255,.75)}
.tb{position:absolute;bottom:0;left:0;height:3px;background:linear-gradient(to right,#3b82f6,#6366f1);width:0%;transition:width linear}
.tb.p{opacity:.45}
#MB{position:fixed;top:70px;right:16px;z-index:200;background:rgba(0,0,0,.5);border:1px solid rgba(255,255,255,.15);border-radius:50%;width:38px;height:38px;display:flex;align-items:center;justify-content:center;cursor:pointer;backdrop-filter:blur(8px);color:#fff}
.pi{position:absolute;inset:0;z-index:20;display:flex;align-items:center;justify-content:center;pointer-events:none;opacity:0;transition:opacity .15s}
.pi svg{filter:drop-shadow(0 2px 12px rgba(0,0,0,.6))}
.s.paused .pi{opacity:1}
.ve{position:absolute;inset:0;z-index:15;display:none;flex-direction:column;align-items:center;justify-content:center;gap:10px;color:rgba(255,255,255,.5);font-size:.85rem}
.s.vf .ve{display:flex}
.s.vf .v{opacity:0}
.hb{position:absolute;z-index:30;pointer-events:none;font-size:56px;line-height:1;transform:scale(0);animation:hP .6s ease-out forwards}
@keyframes hP{0%{transform:scale(0);opacity:1}40%{transform:scale(1.3);opacity:1}70%{transform:scale(1);opacity:1}100%{transform:scale(1.1);opacity:0}}
.ef{height:100dvh;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:16px;color:rgba(255,255,255,.5);text-align:center;padding:40px}
.ef h2{font-family:'Syne',sans-serif;font-size:1.4rem;color:#fff}
.ef p{font-size:.9rem;max-width:280px;line-height:1.6}
.ei{width:64px;height:64px;background:rgba(59,130,246,.15);border-radius:50%;display:flex;align-items:center;justify-content:center;margin-bottom:8px}
.sh{position:absolute;bottom:48px;right:50%;transform:translateX(50%);display:flex;flex-direction:column;align-items:center;gap:4px;animation:bn 1.5s ease-in-out infinite;font-size:.65rem;color:#fff;transition:opacity .4s;opacity:.5}
.sh.h{opacity:0;pointer-events:none}
@keyframes bn{0%,100%{transform:translateX(50%) translateY(0)}50%{transform:translateX(50%) translateY(-6px)}}
.liked .sbi{background:rgba(239,68,68,.4)!important}
.saved .sbi{background:rgba(99,102,241,.4)!important}
</style>

<div id="H">
  <a href="/" class="logo"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>Nox</a>
  <span class="bx">⚡ CLICKZ</span>
  <a href="/products" style="color:rgba(255,255,255,.6);font-size:.8rem;text-decoration:none;">Browse →</a>
</div>
<button id="MB" title="Toggle mute"><svg id="MI" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/><path d="M15.54 8.46a5 5 0 0 1 0 7.07"/><path d="M19.07 4.93a10 10 0 0 1 0 14.14"/></svg></button>
<div id="F">
{C.length===0?(
  <div class="s"><div class="ef"><div class="ei"><svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#3b82f6" stroke-width="2"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg></div><h2>No Clickz yet</h2><p>Be the first seller to post an 8-second product Clickz and reach thousands of builders.</p><a href="/sell/clickz" style="margin-top:8px;background:linear-gradient(135deg,#3b82f6,#6366f1);color:#fff;padding:12px 24px;border-radius:12px;font-family:'Syne',sans-serif;font-weight:700;text-decoration:none;font-size:.9rem;">Post a Clickz →</a></div></div>
):(
  C.map((item:Clickz,i:number)=>(
    <div class="s" data-index={i} data-id={item.id} data-price={item.metadata?.price||'0'} data-category={item.metadata?.category||''} data-ts={(item as any).created_at||''} data-likes={item.metadata?.likes||0} data-views={(item.metadata as any)?.views||0} data-seller-score={(item.metadata as any)?.seller_score||50}>
      <video class="v" src={item.metadata?.video?.url||''} playsinline loop muted preload={i===0?'auto':'none'} poster={item.metadata?.thumbnail?.imgix_url?`${item.metadata.thumbnail.imgix_url}?w=40&blur=20&auto=format`:''} />
      <div class="o"/><div class="tb"/>
      <div class="pi"><svg width="64" height="64" viewBox="0 0 24 24" fill="rgba(255,255,255,.85)" stroke="none"><rect x="6" y="4" width="4" height="16" rx="1"/><rect x="14" y="4" width="4" height="16" rx="1"/></svg></div>
      <div class="ve"><svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>Video unavailable</div>
      <div class="sb">
        <button class="sbb like-btn" data-id={item.id}><div class="sbi"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg></div><span class="lc">{item.metadata?.likes||0}</span></button>
        <button class="sbb share-btn" data-id={item.id} data-slug={item.slug}><div class="sbi"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/></svg></div><span>Share</span></button>
        <a href={`/products/${item.slug}`} class="sbb buy-btn" data-id={item.id}><div class="sbi"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg></div><span>Buy</span></a>
      </div>
      <div class="c">
        <div class="cat">⚡ {item.metadata?.category||'PC Part'}</div>
        <div class="tt">{item.title}</div>
        <div class="sl">by <span>{item.metadata?.seller_name||'Seller'}</span></div>
        <div class="pr">${item.metadata?.price||'—'}</div>
        <div class="ar">
          <a href={`/products/${item.slug}`} class="bvl buy-btn" data-id={item.id}><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>View Full Listing</a>
          <button class="bsv save-btn" data-id={item.id}><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"/></svg></button>
        </div>
      </div>
      {i===0&&<div class="sh" id="SH"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>Scroll</div>}
    </div>
  ))
)}
</div>
</Layout>

<script>
const BS=import.meta.env.COSMIC_BUCKET_SLUG,RK=import.meta.env.COSMIC_READ_KEY,WK=import.meta.env.COSMIC_WRITE_KEY,CA='https://api.cosmicjs.com/v3',PT='nox-user-profiles',VD=16,SD=8000,RE=2;
const CATS=['gpu','cpu','ram','ssd','case','psu','cooler','mobo','monitor','peripheral','kb','mouse','headset','fan','rgb'];
const RMAP:Record<string,string[]>={'newegg.com':['gpu','cpu','ram','ssd','mobo','psu','case','cooler'],'pcpartpicker.com':['gpu','cpu','ram','ssd','mobo','psu','case','cooler'],'microcenter.com':['gpu','cpu','mobo'],'bestbuy.com':['monitor','peripheral'],'amazon.com':['peripheral','rgb','fan'],'reddit.com/r/buildapc':['gpu','cpu','ram'],'reddit.com/r/hardware':['gpu','cpu'],'bhphotovideo.com':['monitor']};
const cl=(v:number)=>Math.max(0,Math.min(1,v));
const dot=(a:number[],b:number[])=>a.reduce((s,v,i)=>s+v*(b[i]??0),0);
const mag=(a:number[])=>Math.sqrt(a.reduce((s,v)=>s+v*v,0));
const cos=(a:number[],b:number[])=>{const m=mag(a)*mag(b);return m?dot(a,b)/m:0};
const catI=(c:string)=>{const i=CATS.findIndex(x=>(c||'').toLowerCase().includes(x));return i<0?.5:(i+1)/CATS.length};
const prN=(p:string)=>cl(Math.log1p(parseFloat(p)||0)/Math.log1p(5000));
const tod=()=>{const h=new Date().getHours();return h<6?0:h<12?1:h<18?2:3};
const lrF=(n:number)=>Math.max(0.005,0.1/Math.sqrt(1+n*0.05));
function getUid():string{let u=localStorage.getItem('nox_uid');if(!u){const fp=[navigator.language,screen.width,screen.height,screen.colorDepth,Intl.DateTimeFormat().resolvedOptions().timeZone,navigator.hardwareConcurrency,(navigator as any).deviceMemory||0].join('|');let h=0;for(let i=0;i<fp.length;i++)h=(Math.imul(31,h)+fp.charCodeAt(i))|0;u='nox_'+Math.abs(h).toString(36)+'_'+Date.now().toString(36);localStorage.setItem('nox_uid',u);}return u;}
async function cGet(u:string){const q=encodeURIComponent(JSON.stringify({type:PT,slug:u}));const r=await fetch(`${CA}/buckets/${BS}/objects?query=${q}&props=id,slug,metadata&read_key=${RK}&limit=1`);if(!r.ok)return null;const d=await r.json();return d?.objects?.[0]||null;}
async function cPost(u:string,m:object){return fetch(`${CA}/buckets/${BS}/objects`,{method:'POST',headers:{'Content-Type':'application/json','Authorization':`Bearer ${WK}`},body:JSON.stringify({title:`Nox User ${u}`,slug:u,type:PT,status:'published',metadata:m})}).then(r=>r.json());}
async function cPatch(id:string,m:object){return fetch(`${CA}/buckets/${BS}/objects/${id}`,{method:'PATCH',headers:{'Content-Type':'application/json','Authorization':`Bearer ${WK}`},body:JSON.stringify({metadata:m})}).then(r=>r.json());}
function iVec(el:HTMLElement):number[]{return[prN(el.dataset.price||'0'),catI(el.dataset.category||''),cl((Date.now()-parseInt(el.dataset.ts||String(Date.now())))/(864e5*30)),cl(parseInt(el.dataset.likes||'0')/500),cl(parseInt(el.dataset.views||'0')/5000),cl(parseInt(el.dataset.sellerScore||'50')/100),...new Array(10).fill(0.5)];}
const defP=()=>({uv:new Array(VD).fill(0.5),bw:4000,bs:0.5,tod:[.25,.25,.25,.25] as [number,number,number,number],seen:{} as Record<string,number>,interactions:0,pixel_cats:[] as string[],last_updated:Date.now()});
const uid=getUid();
let P=defP(),cid2:string|null=null,sTimer:ReturnType<typeof setTimeout>|null=null,sv=0,wStart:number|null=null,curId:string|null=null,sy0=0,st0=0;
const IV:Record<string,number[]>={};
function beacon(cats:string[]){const p=new URLSearchParams({uid,ref:document.referrer,page:location.pathname,tod:String(tod()),cats:cats.join(',')});navigator.sendBeacon?.('/api/tracker/pixel?'+p)||fetch('/api/tracker/pixel?'+p,{method:'GET',keepalive:true}).catch(()=>{});}
function inferCats(r:string):string[]{const rl=r.toLowerCase();for(const[d,c]of Object.entries(RMAP))if(rl.includes(d))return c;return[];}
function applyPCats(){(P.pixel_cats||[]).forEach(c=>{const i=CATS.indexOf(c);if(i>=0)P.uv[1]=cl(P.uv[1]*.95+(i+1)/CATS.length*.05);});}
function sched(){if(sTimer)clearTimeout(sTimer);sTimer=setTimeout(async()=>{P.last_updated=Date.now();const m={...P,uv:JSON.stringify(P.uv)};try{if(cid2)await cPatch(cid2,m);else{const r=await cPost(uid,m);cid2=r?.object?.id||null;}}catch(e){console.warn('[Nox]',e);}},SD);}
function nudge(id:string,sig:number){const iv=IV[id];if(!iv)return;const e=sig-cos(P.uv,iv);P.uv=P.uv.map((v,i)=>cl(v+lrF(P.interactions)*e*(iv[i]??0)));P.interactions++;sched();}
function updBase(w:number,s:number){P.bw=P.bw*.9+w*.1;P.bs=P.bs*.9+s*.1;}
function score(id:string):number{const iv=IV[id];if(!iv)return 0;let s=cos(P.uv,iv);s+=(1-parseFloat(String(iv[2])))*.05;s-=(P.seen[id]||0)*.08;s+=(P.tod[tod()]-.25)*.1;const cs=CATS[Math.round(parseFloat(String(iv[1]))*CATS.length)-1];if(cs&&(P.pixel_cats||[]).includes(cs))s+=.07;return s;}
function rerank(f:HTMLElement){const ss=Array.from(f.querySelectorAll<HTMLElement>('.s'));const a=ss.find(s=>{const r=s.getBoundingClientRect();return r.top>=0&&r.top<innerHeight});const p=a?ss.indexOf(a)+1:0;ss.slice(p).sort((a,b)=>score(b.dataset.id!)-score(a.dataset.id!)).forEach(s=>f.appendChild(s));}
function onEnter(id:string){
  if(curId&&wStart){const el=Date.now()-wStart,sv2=st0>0?Math.abs(window.scrollY-sy0)/(Date.now()-st0+1):.5,ratio=el/Math.max(P.bw,1000),sd=cl(1-sv2/Math.max(P.bs,.01));let sig=ratio>=1.5?.9:ratio>=.9?.75:ratio>=.5?.55:ratio<.2?.1:.4;sig=cl(sig+sd*.1);nudge(curId,sig);updBase(el,sv2);P.seen[curId]=(P.seen[curId]||0)+1;const b=tod();P.tod=P.tod.map((w,i)=>i===b?cl(w*.9+sig*.1):w*.9+.25*.1) as [number,number,number,number];if(++sv%RE===0)rerank(F);}
  curId=id;wStart=Date.now();sy0=window.scrollY;st0=Date.now();
}
async function loadP(){beacon(inferCats(document.referrer));try{const o=await cGet(uid);if(o){cid2=o.id;P={...defP(),...o.metadata};if(typeof P.uv==='string')P.uv=JSON.parse(P.uv);if(!Array.isArray(P.uv)||P.uv.length!==VD)P.uv=new Array(VD).fill(.5);}}catch{P=defP();}applyPCats();}
const F=document.getElementById('F')!,MB=document.getElementById('MB')!,MI=document.getElementById('MI')!,SH=document.getElementById('SH');
let muted=false,cv:HTMLVideoElement|null=null,cs:Element|null=null,cid:string|null=null,ti:ReturnType<typeof setInterval>|null=null,paused=false,te=0;
const MS=`<polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/><line x1="23" y1="9" x2="17" y2="15"/><line x1="17" y1="9" x2="23" y2="15"/>`;
const US=`<polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/><path d="M15.54 8.46a5 5 0 0 1 0 7.07"/><path d="M19.07 4.93a10 10 0 0 1 0 14.14"/>`;
if(SH){const h=()=>SH.classList.add('h');setTimeout(h,3000);F.addEventListener('scroll',h,{once:true});}
window.addEventListener('scroll',()=>{sy0=window.scrollY;st0=Date.now();},{passive:true});
const pa=(s:Element)=>{[s.nextElementSibling,s.nextElementSibling?.nextElementSibling].forEach((n,i)=>{if(!n)return;const v=n.querySelector('video') as HTMLVideoElement|null;if(v&&v.preload!=='auto')v.preload=i===0?'auto':'metadata'})};
const bar=(s:Element)=>s.querySelector('.tb') as HTMLElement;
const startT=(s:Element)=>{bar(s).classList.remove('p');ti=setInterval(()=>{te+=100;const b=bar(s);b.style.transition='width 0.1s linear';b.style.width=Math.min(te/80,100)+'%';if(te>=8000){clearInterval(ti!);rerank(F);s.nextElementSibling?.scrollIntoView({behavior:'smooth'})}},100)};
const stopT=(s:Element)=>{if(ti){clearInterval(ti);ti=null}bar(s).classList.add('p')};
const tog=(s:Element)=>{const v=s.querySelector('video') as HTMLVideoElement;if(!v)return;if(paused){v.play().catch(()=>{});s.classList.remove('paused');paused=false;startT(s)}else{v.pause();s.classList.add('paused');paused=true;stopT(s)}};
const heart=(s:Element,x:number,y:number)=>{const h=document.createElement('div');h.className='hb';h.textContent='❤️';const r=(s as HTMLElement).getBoundingClientRect();h.style.cssText=`left:${x-r.left-28}px;top:${y-r.top-28}px`;s.appendChild(h);h.addEventListener('animationend',()=>h.remove())};
function play(s:Element){const v=s.querySelector('video') as HTMLVideoElement,b=bar(s),id=(s as HTMLElement).dataset.id!;onEnter(id);cid=id;paused=false;te=0;cs=s;if(cv&&cv!==v){cv.pause();cv.currentTime=0;cv.closest('.s')?.classList.remove('paused')}if(ti)clearInterval(ti);b.style.transition='none';b.style.width='0%';b.classList.remove('p');if(v){v.muted=muted;v.currentTime=0;cv=v;v.onerror=()=>{s.classList.add('vf');if(ti)clearInterval(ti)};v.play().catch(()=>{});startT(s);pa(s)}}
async function patchLikes(id:string,n:number){try{await fetch(`/api/clickz/${id}/likes`,{method:'PATCH',headers:{'Content-Type':'application/json'},credentials:'include',body:JSON.stringify({likes:n})})}catch{}}
function hLike(e:Event){e.stopPropagation();const btn=(e.currentTarget as HTMLElement).closest('.like-btn') as HTMLElement;if(!btn)return;const id=btn.dataset.id!,ic=btn.querySelector('.sbi')!,ct=btn.querySelector('.lc')!,lk=btn.classList.toggle('liked');const n=parseInt(ct.textContent||'0')+(lk?1:-1);ct.textContent=String(n);if(lk)nudge(id,.92);patchLikes(id,n);ic.animate([{transform:'scale(1)'},{transform:'scale(1.35)'},{transform:'scale(1)'}],{duration:250,easing:'ease-out'})}
function hSave(e:Event){e.stopPropagation();const b=e.currentTarget as HTMLElement;nudge(b.dataset.id!,.88);b.classList.add('saved')}
function hBuy(e:Event){e.stopPropagation();nudge((e.currentTarget as HTMLElement).dataset.id!,.97)}
function hShare(e:Event){e.stopPropagation();const b=e.currentTarget as HTMLElement,id=b.dataset.id!,sl=b.dataset.slug!;nudge(id,.85);const u=`${location.origin}/products/${sl}`;navigator.share?navigator.share({title:'Check this out on Nox',url:u}):navigator.clipboard.writeText(u).then(()=>alert('Link copied!'))}
const tt=new WeakMap<Element,ReturnType<typeof setTimeout>>();
