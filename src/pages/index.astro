---
import Layout from '@/layouts/Layout.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import ProductCard from '@/components/ProductCard.astro';
import { getProducts } from '@/lib/cosmic';
import type { Product } from '@/types';
<script id="Cookiebot" src="https://consent.cookiebot.com/uc.js" data-cbid="aec6e51e-3549-4745-ae71-d7240d97a863"  type="text/javascript"></script>
const products = await getProducts();
const featuredProducts = products.slice(0, 8);
---

<Layout title="Nox - PC Part Marketplace">
  <Header />
  <script id="Cookiebot" src="https://consent.cookiebot.com/uc.js" data-cbid="aec6e51e-3549-4745-ae71-d7240d97a863"  type="text/javascript"></script>
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Syne:wght@700;800&family=DM+Sans:wght@300;400;500&display=swap');

    :root {
      --bg: #fff;
      --text: #000;
      --muted: rgba(0,0,0,0.6);
      --border: rgba(0,0,0,0.1);
    }

    body {
      background: var(--bg);
      color: var(--text);
      font-family: 'DM Sans', sans-serif;
      margin: 0;
      padding: 0;
    }

    main { max-width: 1200px; margin: 0 auto; padding: 24px; }
    h1, h2 { color: var(--text); margin-bottom: 16px; }
    p { color: var(--muted); line-height: 1.6; margin-bottom: 24px; }

    a { text-decoration: none; }
    .btn-primary, .btn-ghost {
      display: inline-block;
      padding: 12px 24px;
      border-radius: 6px;
      font-weight: 700;
      margin-right: 12px;
      margin-bottom: 12px;
      text-align: center;
      transition: opacity 0.15s, transform 0.1s;
    }
    .btn-primary { background: #000; color: #fff; }
    .btn-primary:hover { opacity: 0.88; transform: scale(0.97); }
    .btn-ghost { background: transparent; border: 1px solid var(--border); color: var(--text); }
    .btn-ghost:hover { opacity: 0.88; transform: scale(0.97); }

    .hero { padding: 80px 0; text-align: center; }
    .hero-btns { display: flex; flex-wrap: wrap; gap: 12px; justify-content: center; margin-top: 24px; }

    .products-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 16px; margin-top: 32px; }
    .cats-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(150px, 1fr)); gap: 16px; margin-top: 32px; }
    .cat-card { padding: 24px; border: 1px solid var(--border); border-radius: 10px; text-align: center; transition: transform 0.15s; }
    .cat-card:hover { transform: translateY(-2px); }
    .cat-emoji { font-size: 2rem; margin-bottom: 8px; }
    .cat-name { font-weight: 700; }

    .section { padding: 80px 0; }
  </style>

  <main>

    <!-- Hero -->
    <section class="hero">
      <h1>PC Part Marketplace</h1>
      <p>Buy and sell verified PC components with confidence.</p>
      <div class="hero-btns">
        <a href="/products" class="btn-primary">Browse Components</a>
        <a href="/become-seller" class="btn-ghost">Start Selling</a>
        <a href="/clickz" class="btn-primary">⚡ Clickz Feed</a>
        <a href="/sell/clickz" class="btn-ghost">Post a Clickz</a>
      </div>
    </section>

    <!-- Featured Components -->
    <section class="section">
      <h2>Featured Components</h2>
      <p>Verified and ready to ship</p>
      {featuredProducts.length > 0 ? (
        <div class="products-grid">
          {featuredProducts.map((product: Product) => (
            <ProductCard product={product} />
          ))}
        </div>
      ) : (
        <p>No components yet. Be the first to list!</p>
      )}
    </section>

    <!-- Categories -->
    <section class="section">
      <h2>Component Categories</h2>
      <div class="cats-grid">
        {[
          { name: 'Graphics Cards', icon: '🎮' },
          { name: 'Processors', icon: '⚡' },
          { name: 'Motherboards', icon: '🔧' },
          { name: 'Memory (RAM)', icon: '💾' },
          { name: 'Storage', icon: '💿' },
          { name: 'Power Supplies', icon: '🔋' },
          { name: 'Cooling', icon: '❄️' },
          { name: 'Cases', icon: '📦' },
        ].map(cat => (
          <a href={`/products?category=${cat.name.toLowerCase()}`} class="cat-card">
            <div class="cat-emoji">{cat.icon}</div>
            <div class="cat-name">{cat.name}</div>
          </a>
        ))}
      </div>
    </section>

    <!-- CTA -->
    <section class="section" style="text-align:center;">
      <h2>Ready to Build or Upgrade?</h2>
      <p>Join our community of PC builders buying and selling verified components.</p>
      <a href="/products" class="btn-primary">Browse Components</a>
      <a href="/signup" class="btn-ghost">Create Account</a>
    </section>

  </main>

  <Footer />
</Layout>
